<!-- AMP UPSELL Minified code -->
<script>
  function ampAddNavidiumWidget() {
    const d = document.querySelector('.amp-cart-drawer .amp-cart__footer:not(.edited)');
    d && (d.insertAdjacentHTML('beforebegin', '<div class="nvd-mini"></div>'), d.classList.add('edited'));
  }
  (window.AMP_CART_LOADED = () => {
    ampAddNavidiumWidget();
  }),
    (window.AMP_CART_UPDATED = (d, e) => {
      const t = document.querySelector('.cart-count-bubble [aria-hidden]');
      return t && (t.textContent = d.item_count), ampAddNavidiumWidget(), { ...e };
    });
  
  {% comment %} function hideShippingProtection() {
    const products = document.querySelectorAll('.amp-cart__cart-line');
    products.forEach((product) => {
      if (product.querySelector('.amp-cart__cart-line-title').innerText === 'Navidium Shipping Protection') {
        product.remove();
      }
    });
  }
  setInterval(hideShippingProtection, 500); {% endcomment %}
</script> 
