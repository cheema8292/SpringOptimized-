	<script>
  const hideNavidium = setInterval(function() {
    const cartLines = document.querySelectorAll('.amp-cart__cart-line');

    cartLines.forEach(line => {
      const titleEl = line.querySelector('.amp-cart__cart-line-title');
      if(titleEl && titleEl.textContent.trim() === "Navidium Shipping Protection") {
        line.style.display = "none";
      }
    });

    if(cartLines.length > 0) {
      clearInterval(hideNavidium);
    }
  }, 500);
</script> {% endcomment %}

<script>
(function() {

  function hideNavidiumProduct() {
    document.querySelectorAll('.amp-cart__cart-line').forEach(line => {
      const title = line.querySelector('.amp-cart__cart-line-title');
      if (title && title.textContent.trim() === 'Navidium Shipping Protection') {
        line.style.display = 'none';
      }
    });
  }

  function initObserver() {
    const cartDrawer = document.querySelector('.amp-cart-drawer');
    if (!cartDrawer) return;

    // observer cart open/close changes
    const observer = new MutationObserver(mutations => {
      mutations.forEach(mutation => {
        // cart open হলে hide trigger হবে
        if (cartDrawer.classList.contains('amp-cart--open')) {
          hideNavidiumProduct();
        }
      });
    });

    observer.observe(cartDrawer, {
      attributes: true,
      attributeFilter: ['class']
    });
  }

  const waitForCart = setInterval(() => {
    if (document.querySelector('.amp-cart-drawer')) {
      clearInterval(waitForCart);
      initObserver();
    }
  }, 300);

})();
</script>




