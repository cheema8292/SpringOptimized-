{% render 'rapid-search-results-template-v2' %}
{{ 'main-collection.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'search.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'blog-post.css' | asset_url | stylesheet_tag }}
{{ 'blog-card.css' | asset_url | stylesheet_tag }}
<script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>

<style>
  #shopify-section-{{ section.id }}{
    --topSpacer: {{ section.settings.top_space_desktop }}px;
    --bottomSpacer:{{ section.settings.bottom_space_desktop }}px;
    --sectionRadius:{{ section.settings.banner_border_radius }}px;
    --columnCount : {{ section.settings.column_count }};
    --mediaHeight: {{ section.settings.desktop_custom_height }}px;

    {% if section.settings.enable_overlay %}
      {% if section.settings.overlay_style == 'gradient' %}
        --imageOverlay: {{ section.settings.overlay_gradient }};
      {% else %}
        --imageOverlay: rgba({{ section.settings.overlay_solid.rgba }});
      {% endif %}
    {% endif %}
  }
  #shopify-section-{{ section.id }} .main-search-result-articles{
    --blockRadius:{{ section.settings.card_radius }}px;
  }
  @media only screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      --topSpacer: {{ section.settings.top_space_mobile }}px;
      --bottomSpacer: {{ section.settings.bottom_space_mobile }}px;
      --mediaHeight: {{ section.settings.mobile_custom_height }}px;
      --columnCount : {{ section.settings.mobile_column }};
      {% if section.settings.banner_border_radius > 30 %}
        --sectionRadius: calc({{ section.settings.banner_border_radius }}px / 2);
      {% else %}
         --sectionRadius:{{ section.settings.banner_border_radius }}px;
      {% endif %}
    }
  }
</style>

{% liquid
  assign loading = 'lazy'
  if section.index <= 3
    assign loading = 'eager'
    assign fetch_priority = 'high'
  else
    assign fetch_priority = 'auto'
  endif
  assign total_active_filter_counts = 0
  for filter in search.filters
    assign total_active_filter_counts = total_active_filter_counts | plus: filter.active_values.size
    if filter.type == 'price_range'
      assign min = filter.min_value.value
      assign max = filter.max_value.value
      if min != null or max != null
        assign total_active_filter_counts = total_active_filter_counts | plus: 1
      endif
    endif
  endfor
%}

<div
  class="color-scheme {{ section.settings.color_scheme }} section-spacing color-{{ section.settings.color_type }}"
  {% if section.settings.header_transparent %}
    allow-header-transparent
  {% endif %}
  data-id="{{ section.id }}"
>
  <div class="main-search-outer">
    <div class="{{ section.settings.banner_container_width }}">
      <div class="search-page-banner-wrapper d-grid{% if section.settings.rounded_corners == 'all' %} {{ section.settings.rounded_corners_type }}{% endif %}">
        {% if section.settings.image_picker != blank %}
          <div class="search-page-banner-media height-100 width-100">
            <div class="media-card media-fixed media-card-overlay">
              {% liquid
                assign default_alt = 'Search page banner image' | escape
                assign image_alt = section.settings.image_picker.alt | default: default_alt
              %}
              {{
                section.settings.image_picker
                | image_url: width: 3840, format: 'webp'
                | image_tag:
                  sizes: '(max-width: 479px) 100vw, (max-width: 767px) 100vw, (max-width: 1023px) 100vw, 100vw',
                  widths: '180, 240, 320, 375, 480, 600, 768, 900, 1024, 1280, 1536, 1920, 2560, 3840',
                  decoding: 'async',
                  loading: loading,
                  fetchpriority: fetch_priority,
                  alt: image_alt
              }}
            </div>
          </div>
        {% endif %}
        <div class="search-page-banner-content{% if section.settings.banner_container_width == 'container-full' %} {{ section.settings.banner_inner_container_width }}{% endif %}">
          <div class="search-page-banner-content-inner">
            <div class="search-page-banner-left-cnt">
              <{{ section.settings.heading_tag }} class="search-page-banner-heading {{ section.settings.heading_size }}{% if section.settings.image_picker != blank %} overlay-text{% endif %}">
                {{ 'templates.search.title' | t }}
              </{{ section.settings.heading_tag }}>
              <main-search class="main-search-input-box d-block">
                <form action="{{ routes.search_url }}" method="get" role="search" class="search-input-box">
                  {% liquid
                    assign search_type = 'product'
                  %}
                  <input type="hidden" name="type" value="{{ search_type }}">
                  <button type="submit" aria-label="Submit" class="svg-wrapper">
                    <svg
                      viewBox="0 0 20 20"
                      fill="none"
                    >
                      <path d="M19 19L15.5967 15.5963M18.0385 9.5202C18.0385 14.2258 14.2243 18.0405 9.5192 18.0405C4.8142 18.0405 1 14.2258 1 9.5202C1 4.81464 4.8142 1 9.5192 1C14.2243 1 18.0385 4.81464 18.0385 9.5202Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
                    </svg>
                  </button>
                  <label class="visually-hidden" for="main-search-input__box">Search</label>
                  <input
                    id="main-search-input__box"
                    class="form-control"
                    type="search"
                    name="q"
                    value="{{ search.terms | escape  }}"
                    placeholder="{{ 'general.search.search' | t }}"
                    aria-label="Search"
                    data-input-search
                  >
                  <button
                    type="reset"
                    value="Reset"
                    class="text-small text-underline{% if search.terms == blank %} hidden{% endif %}"
                    data-search-clear=""
                    aria-label="Clear search input"
                  >
                    {{ 'templates.search.clear' | t }}
                  </button>
                </form>
              </main-search>
            </div>
            {%- if search.performed -%}
              <div class="main-search-count-text" search-count-text>
                <span>{{ 'templates.search.results_with_count_and_term' | t: count: search.results_count }}</span>
                <strong> “{{ search.terms }}”</strong>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
    {% if search.performed %}
      <div class="{{ section.settings.container_width }}">
        {% if search.performed %}
          {% if search.types contains 'product' %} 
            {% if section.settings.enable_filtering or section.settings.enable_sorting %}
               {% if search.filters != empty %}
              <div class="collection-topbar border-bottom" filter-top-bar>
                <div class="facet-wrapper">
                  {% if section.settings.desktop_filter_style == 'horizontal' %}
                    <horizontal-facets-drawer class="facet-button" tabindex="0">
                      <span class="svg-wrapper facet-button-icon">
                        <svg viewBox="0 0 14 13" fill="none">
                          <path fill-rule="evenodd" clip-rule="evenodd" d="M10.9987 6.50065C12.4714 6.50065 13.6654 5.2321 13.6654 3.66732C13.6654 2.10251 12.4714 0.833984 10.9987 0.833984C9.75616 0.833984 8.7121 1.73695 8.41603 2.95898H0.998698C0.630511 2.95898 0.332031 3.27612 0.332031 3.66732C0.332031 4.05852 0.630511 4.37565 0.998698 4.37565H8.41603C8.7121 5.59767 9.75616 6.50065 10.9987 6.50065ZM9.66536 3.66732C9.66536 4.44972 10.2623 5.08398 10.9987 5.08398C11.7351 5.08398 12.332 4.44972 12.332 3.66732C12.332 2.88491 11.7351 2.25065 10.9987 2.25065C10.2623 2.25065 9.66536 2.88491 9.66536 3.66732ZM0.332031 9.33398C0.332031 7.76921 1.52594 6.50065 2.9987 6.50065C4.24126 6.50065 5.28532 7.40363 5.58135 8.62565H12.9987C13.3669 8.62565 13.6654 8.94277 13.6654 9.33398C13.6654 9.7252 13.3669 10.0423 12.9987 10.0423H5.58135C5.28532 11.2643 4.24126 12.1673 2.9987 12.1673C1.52594 12.1673 0.332031 10.8988 0.332031 9.33398ZM4.33203 9.33398C4.33203 8.55156 3.73508 7.91732 2.9987 7.91732C2.26232 7.91732 1.66536 8.55156 1.66536 9.33398C1.66536 10.1164 2.26232 10.7507 2.9987 10.7507C3.73508 10.7507 4.33203 10.1164 4.33203 9.33398Z" fill="currentColor"/>
                        </svg>
                      </span>
                      <span class="heading-font" data-toggle-filter>
                        {%- if section.settings.open_by_default %}Hide{% else %}Show{% endif %} Filters</span
                      >
                      <div filter-active-count>
                        {%- if total_active_filter_counts and total_active_filter_counts > 0 -%}
                          <span>{{ total_active_filter_counts }}</span>
                        {%- endif -%}
                      </div>
                    </horizontal-facets-drawer>
                  {% else %}
                    <facets-drawer class="facet-button" facet-drawer-btn facet-drawer-btn-mobile tabindex="0">
                      <span class="svg-wrapper facet-button-icon">
                        <svg viewBox="0 0 14 13" fill="none">
                          <path fill-rule="evenodd" clip-rule="evenodd" d="M10.9987 6.50065C12.4714 6.50065 13.6654 5.2321 13.6654 3.66732C13.6654 2.10251 12.4714 0.833984 10.9987 0.833984C9.75616 0.833984 8.7121 1.73695 8.41603 2.95898H0.998698C0.630511 2.95898 0.332031 3.27612 0.332031 3.66732C0.332031 4.05852 0.630511 4.37565 0.998698 4.37565H8.41603C8.7121 5.59767 9.75616 6.50065 10.9987 6.50065ZM9.66536 3.66732C9.66536 4.44972 10.2623 5.08398 10.9987 5.08398C11.7351 5.08398 12.332 4.44972 12.332 3.66732C12.332 2.88491 11.7351 2.25065 10.9987 2.25065C10.2623 2.25065 9.66536 2.88491 9.66536 3.66732ZM0.332031 9.33398C0.332031 7.76921 1.52594 6.50065 2.9987 6.50065C4.24126 6.50065 5.28532 7.40363 5.58135 8.62565H12.9987C13.3669 8.62565 13.6654 8.94277 13.6654 9.33398C13.6654 9.7252 13.3669 10.0423 12.9987 10.0423H5.58135C5.28532 11.2643 4.24126 12.1673 2.9987 12.1673C1.52594 12.1673 0.332031 10.8988 0.332031 9.33398ZM4.33203 9.33398C4.33203 8.55156 3.73508 7.91732 2.9987 7.91732C2.26232 7.91732 1.66536 8.55156 1.66536 9.33398C1.66536 10.1164 2.26232 10.7507 2.9987 10.7507C3.73508 10.7507 4.33203 10.1164 4.33203 9.33398Z" fill="currentColor"/>
                        </svg>
                      </span>
                      <span class="heading-font">{{ 'products.facets.filter_and_sort' | t }}</span>
                      <div filter-active-count>
                        {% if total_active_filter_counts > 0 %}
                          <span>{{ total_active_filter_counts }}</span>
                        {% endif %}
                      </div>
                    </facets-drawer>
                  {% endif %}
                </div>

                {% if section.settings.show_total_count %}
                  <div class="collection-product-count text" total-product-count>
                    {{ collection.products_count }} products
                  </div>
                {% endif %}
              </div>
              {% if section.settings.desktop_filter_style == 'horizontal' %}
                {% render 'horizontal-facets',
                  results: search,
                  enable_filtering: section.settings.enable_filtering,
                  enable_sorting: section.settings.enable_sorting,
                  section_id: 'main-search',
                  applied_filter_style: section.settings.applied_filter_style,
                  section: section
                %}
              {% endif %}
              {% endif %}
            {% endif %}
          {% endif %}
        {% endif %}
        <div class="main-search-wrapper">
          <div class="main-search-tabs">
            <ul class="tab-nav-wrapper">
              <li class="tab-nav-item">
                <a
                  href="{{ '?type=product&options%5Bprefix%5D=last&q=' | append: search.terms | escape }}"
                  class="tab-nav-link text-medium{% if search.types contains 'product' %} active{% endif %}"
                  tab-heading=""
                  data-tab="productsTab"
                >
                  {{ 'templates.search.products' | t }}
                </a>
              </li>
              <li class="tab-nav-item">
                <a
                  href="{{ '?type=article&options%5Bprefix%5D=last&q=' | append: search.terms | escape }}"
                  class="tab-nav-link text-medium{% if search.types contains 'article' %} active{% endif %}"
                  tab-heading=""
                  data-tab="articleTab"
                >
                  {{ 'templates.search.article' | t }}
                </a>
              </li>
              <li class="tab-nav-item">
                <a
                  href="{{ '?type=page&options%5Bprefix%5D=last&q=' | append: search.terms | escape }}"
                  class="tab-nav-link text-medium{% if search.types contains 'page' %} active{% endif %}"
                  tab-heading=""
                  data-tab="pagesTab"
                >
                  {{ 'templates.search.page' | t }}
                </a>
              </li>
            </ul>
          </div>
          {%- if search.performed -%}
            {% if search.types contains 'product' %}
              <div class="collection-content-wrapper" product-list-wrapper>
                {% paginate search.results by section.settings.products_limit %}
                  {% if section.settings.enable_filtering or section.settings.enable_sorting %}
                    {% render 'facets',
                      results: search,
                      enable_filtering: section.settings.enable_filtering,
                      enable_sorting: section.settings.enable_sorting,
                      section_id: 'main-search',
                      applied_filter_style: section.settings.applied_filter_style,
                      section: section
                    %}
                  {% endif %}
                  <div class="collection-products flex-grow" data-section_id="{{ section.id }}">
                    {% if search.results.size > 0 %}
                      <div class="collection-products-list" product-listing-wrapper>
                        {%- for item in search.results limit: section.settings.products_limit -%}
                          {%- case item.object_type -%}
                            {%- when 'product' -%}
                              <div class="collection-product-item">
                                {% render 'product-card',
                                  product_card: item,
                                  section: section,
                                  loading_image: loading,
                                  aspect_ratio_image: section.settings.aspect_ratio
                                %}
                              </div>
                          {%- endcase -%}
                        {% endfor %}
                      </div>
                      {% render 'paginate', paginate: paginate, pagination_type: section.settings.pagination_type %}
                    {% else %}
                      {% render 'empty-card', source: 'main-collection' %}
                    {% endif %}
                  </div>
                {% endpaginate %}
                {% if section.settings.enable_filtering or section.settings.enable_sorting %}
                   {% if search.filters != empty %}
                  <div class="sticky-filter-bar md-none d-flex">
                    <div class="facet-wrapper">
                      <facets-drawer class="facet-button" facet-drawer-btn facet-drawer-btn-mobile>
                        <span class="svg-wrapper facet-button-icon">
                          <svg viewBox="0 0 14 13" fill="none">
                            <path fill-rule="evenodd" clip-rule="evenodd" d="M10.9987 6.50065C12.4714 6.50065 13.6654 5.2321 13.6654 3.66732C13.6654 2.10251 12.4714 0.833984 10.9987 0.833984C9.75616 0.833984 8.7121 1.73695 8.41603 2.95898H0.998698C0.630511 2.95898 0.332031 3.27612 0.332031 3.66732C0.332031 4.05852 0.630511 4.37565 0.998698 4.37565H8.41603C8.7121 5.59767 9.75616 6.50065 10.9987 6.50065ZM9.66536 3.66732C9.66536 4.44972 10.2623 5.08398 10.9987 5.08398C11.7351 5.08398 12.332 4.44972 12.332 3.66732C12.332 2.88491 11.7351 2.25065 10.9987 2.25065C10.2623 2.25065 9.66536 2.88491 9.66536 3.66732ZM0.332031 9.33398C0.332031 7.76921 1.52594 6.50065 2.9987 6.50065C4.24126 6.50065 5.28532 7.40363 5.58135 8.62565H12.9987C13.3669 8.62565 13.6654 8.94277 13.6654 9.33398C13.6654 9.7252 13.3669 10.0423 12.9987 10.0423H5.58135C5.28532 11.2643 4.24126 12.1673 2.9987 12.1673C1.52594 12.1673 0.332031 10.8988 0.332031 9.33398ZM4.33203 9.33398C4.33203 8.55156 3.73508 7.91732 2.9987 7.91732C2.26232 7.91732 1.66536 8.55156 1.66536 9.33398C1.66536 10.1164 2.26232 10.7507 2.9987 10.7507C3.73508 10.7507 4.33203 10.1164 4.33203 9.33398Z" fill="currentColor"/>
                          </svg>
                        </span>
                        <span>{{ 'products.facets.filter_and_sort' | t }}</span>
                        <div filter-active-count>
                          {% if total_active_filter_counts > 0 %}
                            <span>{{ total_active_filter_counts }}</span>
                          {% endif %}
                        </div>
                      </facets-drawer>
                    </div>
                    {% comment %}
                      <div class="compare-switch">
                        <input
                          id="compare-product-toggle"
                          class="vh"
                          type="checkbox"
                          role="switch"
                          aria-label="{{ 'sections.main-collection.compare' | t }}"
                          data-max-compare-limit="{{ settings.max_product_compare }}"
                        >
                        <label class="switch-text text" for="compare-product-toggle">
                          {{- 'sections.main-collection.compare' | t -}}
                        </label>
                      </div>
                    {% endcomment %}
                  </div>
                        {% endif %}
                {% endif %}
              </div>
            {% elsif search.types contains 'article' %}
              {% if search.results.size > 0 %}
                {% paginate search.results by 12 %}
                  <div
                    class="main-search-result-articles blog-grid-wrapper blog-style-{{ section.settings.card_style }}"
                    product-listing-wrapper
                  >
                    {%- for item in search.results -%}
                      {%- case item.object_type -%}
                        {%- when 'article' -%}
                          {% render 'blog-card',
                            article_data: item,
                            item_index: forloop.index,
                            section: section,
                            image_ratio: section.settings.blog_aspect_ratio,
                            source_page: 'main-blog',
                            title_size: section.settings.blog_title_size,
                            description_size: section.settings.blog_description_size
                          %}
                      {%- endcase -%}
                    {%- endfor -%}
                  </div>
                  {% render 'paginate', paginate: paginate, pagination_type: section.settings.pagination_type %}
                {% endpaginate %}
              {% else %}
                {% render 'empty-card', source: 'predictive-search', terms: search.terms %}
              {% endif %}
            {% elsif search.types contains 'page' %}
              {% if search.results.size > 0 %}
                {% paginate search.results by 12 %}
                  <div class="main-search-result-pages">
                    <ul class="search-tab-page-list" product-listing-wrapper>
                      {%- for item in search.results -%}
                        {%- case item.object_type -%}
                          {%- when 'page' -%}
                            <li class="search-tab-page-item">
                              <div class="search-page-icon">
                                {% render 'svg-icons', icon_type: 'page-icon' %}
                              </div>
                              <a href="{{ item.url }}" class="search-tab-page-link text-large heading-font">
                                {{- item.title }}
                                {% render 'svg-icons', icon_type: 'arrow-upright' %}
                              </a>
                            </li>
                        {%- endcase -%}
                      {%- endfor -%}
                    </ul>
                    {% render 'paginate', paginate: paginate, pagination_type: section.settings.pagination_type %}
                  </div>
                {% endpaginate %}
              {% else %}
                {% render 'empty-card', source: 'predictive-search', terms: search.terms %}
              {% endif %}
            {% endif %}
          {%- elsif search.performed -%}
            {% render 'empty-card', source: 'predictive-search', terms: search.terms %}
          {%- endif -%}
        </div>
      </div>
    {% endif %}
  </div>
</div>
<script>
  class MainSearch extends HTMLElement {
    constructor() {
      super();

      this.input = this.querySelector('[data-input-search]');
      this.resetButton = this.querySelector('[data-search-clear]');

      if (!this.input || !this.resetButton) return;

      if (this.resetButton.tagName === 'BUTTON' && !this.resetButton.hasAttribute('type')) {
        this.resetButton.type = 'button';
      }

      this.input.addEventListener('input', () => this.toggleResetButton());
      this.resetButton.addEventListener('click', (e) => {
        e.preventDefault();
        this.clearInput();
      });

      this.toggleResetButton();
    }

    toggleResetButton() {
      const hasValue = this.input.value.trim() !== '';
      this.resetButton.classList.toggle('hidden', !hasValue);
    }

    clearInput() {
      this.input.value = '';
      this.input.dispatchEvent(new Event('input', { bubbles: true, cancelable: true }));
      this.toggleResetButton();
      this.input.focus();
    }
  }

  customElements.define('main-search', MainSearch);
</script>
{% schema %}
{
  "name": "t:sections.main-search.name",
  "class": "main-search-section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.headers.general"
    },
    {
      "type": "checkbox",
      "id": "header_transparent",
      "label": "t:sections.all.headers.header_transparent.label",
      "default": false,
      "info": "t:sections.all.headers.header_transparent.info"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "t:sections.all.settings.colors.label"
    },
    {
      "type": "select",
      "id": "color_type",
      "label": "t:sections.all.settings.color_background.label",
      "default": "solid",
      "options": [
        {
          "label": "t:sections.all.settings.color_background.options.background_solid",
          "value": "solid"
        },
        {
          "label": "t:sections.all.settings.color_background.options.background_gradiant",
          "value": "gradient"
        }
      ]
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "t:sections.all.settings.container_width.label",
      "default": "container-narrow",
      "options": [
        {
          "label": "t:sections.all.settings.container_width.small.label",
          "value": "container-small"
        },
        {
          "label": "t:sections.all.settings.container_width.standard.label",
          "value": "container"
        },
        {
          "label": "t:sections.all.settings.container_width.container_wide.label",
          "value": "container-wide"
        },
        {
          "label": "t:sections.all.settings.container_width.container_edge.label",
          "value": "container-narrow"
        }
      ]
    },
    {
      "type": "range",
      "id": "column_count",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "t:sections.main-search.settings.column_count.label"
    },
    {
      "type": "select",
      "id": "mobile_column",
      "label": "t:sections.main-search.settings.mobile_column.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.all.settings.mobile_layout.mobile_column_count.options__0.label"
        },
        {
          "value": "2",
          "label": "t:sections.all.settings.mobile_layout.mobile_column_count.options__1.label"
        }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "label": "t:sections.main-search.settings.pagination_type.label",
      "id": "pagination_type",
      "default": "page-number",
      "options": [
        {
          "label": "t:sections.main-search.settings.pagination_type.options.option_1",
          "value": "infinite"
        },
        {
          "label": "t:sections.main-search.settings.pagination_type.options.option_2",
          "value": "load-more"
        },
        {
          "label": "t:sections.main-search.settings.pagination_type.options.option_3",
          "value": "page-number"
        }
      ]
    },
    {
      "type": "header",
