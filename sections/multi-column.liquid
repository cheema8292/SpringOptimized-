    },
    {
      "type": "select",
      "id": "image_width",
      "label": "t:sections.multicolumn.settings.image_width.label",
      "default": "large",
      "visible_if": "{{ section.settings.image_fullwidth == false }}",
      "options": [
        {
          "label": "t:sections.multicolumn.settings.image_width.options.large.label",
          "value": "large"
        },
        {
          "label": "t:sections.multicolumn.settings.image_width.options.medium.label",
          "value": "medium"
        },
        {
          "label": "t:sections.multicolumn.settings.image_width.options.small.label",
          "value": "small"
        }
      ]
    },
    {
      "type": "select",
      "id": "image_style",
      "label": "t:sections.multicolumn.settings.image_style.label",
      "default": "rounded",
      "options": [
        {
          "label": "t:sections.multicolumn.settings.image_style.options.square.label",
          "value": "square"
        },
        {
          "label": "t:sections.multicolumn.settings.image_style.options.circle.label",
          "value": "rounded"
        }
      ]
    },
    {
      "type": "range",
