{%- unless product.has_only_default_variant -%}
  {% if product != blank %}
    {% capture has_color_options %}
    {%- assign has_catagory_swatches = false -%}
    {%- for option in product.options_with_values -%}
      {%- assign option_id = forloop.index0 -%}
      {%- assign swatch_count = option.values | map: 'swatch' | compact | size -%}
      {% comment %}
        Check if the option has a color trigger (e.g., "color" in the option name).
      {% endcomment %}
      {% assign has_color_trigger = false %}
      {% if settings.color_name != blank %}
        {% assign swatch_trigger_list = settings.color_name | downcase | split: ',' %}
        {% assign downcased_option = option.name | downcase %}
        {% for trigger in swatch_trigger_list %}
          {% assign swatch_trigger = trigger | strip %}
          {% if downcased_option contains swatch_trigger %}
            {% assign has_color_trigger = true %}
            {% break %}
          {% endif %}
        {% endfor %}
      {% endif %}
      {% comment %}
        Render swatches only if either `swatch_count > 0` or `has_color_trigger` is true.
        If neither is true, skip this option entirely.
      {% endcomment %}
      {% if swatch_count > 0 %}
        {%- assign has_catagory_swatches = true -%}
        {%- assign options_size = option.values.size -%}
        <variants-card class="d-block">
          <ul class="variant-swatches-list round small-swatches">
            {%- for option_value in option.values limit: settings.swatches_count -%}
              {% assign style = settings.product_card_variant | escape %}
              {%- assign swatch_fallback = null %}
              {% liquid
                assign swatch_image = blank
                assign option_disabled = true
                if option_value.available
                  assign option_disabled = false
                endif
              %}
              {% if style == 'color_swatch' %}
                {% if option_value.swatch != blank and option_value.swatch.image %}
                  {%- assign swatch_image = option_value.swatch.image | image_url: width: 50 %}
                {%- elsif option_value.swatch != blank and option_value.swatch.color -%}
                  {%- assign swatch_fallback = option_value.swatch.color %}
                {%- else -%}
                  {%- assign swatch_fallback = option_value %}
                {%- endif -%}

              {%- elsif style == 'variant_image' -%}
                {%- for variant in product.variants -%}
                  {%- if variant.options[option_id] == option_value and variant.image -%}
                    {%- assign swatch_image = variant.image | image_url: width: 50 %}
                    {%- break -%}
                  {%- else -%}
                    {%- assign swatch_fallback = option_value %}
                  {%- endif -%}
                {%- endfor -%}
              {% else %}
                {%- assign swatch_fallback = option_value | escape %}
              {%- endif -%}
                
                  <li
                    class="swatches-list-item cursor-pointer{% if swatch_image != blank %} has-swatch-image{% endif %}{% if option_disabled %} variant-disabled{% endif %}"
                    data-product-url-card="{{ option_value.product_url }}"
                    data-variant-id-card="{{ option_value.variant.id }}"
                    data-option-value-id-card="{{ option_value.id }}"
                    data-option-value-card="{{ option_value | escape }}"
                    data-tooltip
                  >
                    <span
                      class="swatch-label"
                      style="{% if swatch_image != blank  %}--swatchImage:url({{ swatch_image }});{%  elsif swatch_fallback != blank %}--colorPalette:{{ swatch_fallback }};{% endif %}"
                    >
                    </span>
                    <div class="tooltip body-font">{{ option_value | escape }}</div>
                  </li>
            {%- endfor -%}
            {%- if option.values.size > settings.swatches_count -%}
              <li class="cursor-pointer see-more-swatches text-small">
                <a href="{{ product.url }}" class="d-block" aria-label="{{ product.title }}">+{{ option.values.size | minus: settings.swatches_count }}</a>
              </li>
            {%- endif -%}
          </ul>
        </variants-card>
        {% break %}
      {% elsif has_color_trigger and has_catagory_swatches == false %}
        {%- assign options_size = option.values.size -%}
          <variants-card class="d-block">
          <ul class="variant-swatches-list round small-swatches">
            {%- for option_value in option.values limit: settings.swatches_count -%}
              {% assign style = settings.product_card_variant | escape %}
              {%- assign swatch_fallback = null %}
              {% liquid
                assign swatch_image = blank
                assign option_disabled = true
                if option_value.available
                  assign option_disabled = false
                endif
              %}

              {% if style == 'color_swatch' %}
                {%- assign swatch_fallback = option_value %}
              {%- elsif style == 'variant_image' -%}
                {%- for variant in product.variants -%}
                  {%- if variant.options[option_id] == option_value and variant.image -%}
                    {%- assign swatch_image = variant.image | image_url: width: 50 %}
                    {%- break -%}
                  {%- else -%}
                    {%- assign swatch_fallback = option_value %}
                  {%- endif -%}
                {%- endfor -%}
              {% else %}
                {%- assign swatch_fallback = option_value | escape %}
              {%- endif -%}
              {% if has_color_trigger %}
                <li
                  class="swatches-list-item cursor-pointer{% if swatch_image != blank %} has-swatch-image{% endif %}{% if option_disabled %} variant-disabled{% endif %}"
                  data-product-url-card="{{ option_value.product_url }}"
                  data-variant-id-card="{{ option_value.variant.id }}"
                  data-option-value-id-card="{{ option_value.id }}"
                  data-option-value-card="{{ option_value | escape }}"
                  data-tooltip
                >
                  <span
                    class="swatch-label"
                    style="{% if swatch_image != blank  %}--swatchImage:url({{ swatch_image }});{%  elsif swatch_fallback != blank %}--colorPalette:{{ swatch_fallback }};{% endif %}"
                  >
                    
                  </span>
                  <div class="tooltip body-font">{{ option_value | escape }}</div>
                </li>
              {% endif %}
            {%- endfor -%}
            {%- if option.values.size > settings.swatches_count -%}
              <li class="cursor-pointer see-more-swatches text-small">
                <a href="{{ product.url }}" class="d-block" aria-label="{{ product.title }}">+{{ option.values.size | minus: settings.swatches_count }}</a>
              </li>
            {%- endif -%}
          </ul>
        </variants-card>
        {% break %}
      {% endif %}
    {%- endfor -%}
  {% endcapture %}
    {% if options_size == 1 and settings.hide_single_swatch %}
      {% assign hide_swatches = true %}
    {% endif %}
    {% if options_size > 0 and hide_swatches != true %}
      <div class="product-card-variant-colors color-swatches-box">
        {{ has_color_options }}
      </div>
    {% endif %}
  {% endif %}
{%- endunless -%}
