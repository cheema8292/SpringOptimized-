<script>
  document.addEventListener('mouseup', (e) => {
    if (
      !e.target.closest('.amp-embedded-volume-discount__blocks__content__discounts__discount') ||
      e.target.closest('.amp-embedded-volume-discount__blocks__content__discount-radio-button')
    )
      return;

    let radioInput = e.target
      .closest('.amp-embedded-volume-discount__blocks__content__discounts__discount')
      ?.querySelector('.amp-embedded-volume-discount__blocks__content__discount-radio-button-item');

    radioInput?.click();
  });

  (function () {
    const TARGET_TITLE = 'shipping protection';
    let scheduled = false;

    function hideShippingProtection(root = document) {
      const items = root.querySelectorAll('.amp-embedded-product-upsells__upsell-item:not([data-sc-hidden])');
      for (const item of items) {
        const title = item.querySelector('.amp-embedded-product-upsells__upsell-item-title');
        if (title && title.textContent.trim().toLowerCase() === TARGET_TITLE) {
          item.style.display = 'none';
          item.setAttribute('data-sc-hidden', '1');
        }
      }
    }

    // initial
    hideShippingProtection();

    const observer = new MutationObserver((mutations) => {
      if (scheduled) return;
      scheduled = true;

      requestAnimationFrame(() => {
        scheduled = false;

        // Fast path: only scan inside added nodes (when possible)
        for (const m of mutations) {
          for (const node of m.addedNodes) {
            if (node.nodeType === 1) hideShippingProtection(node);
          }
        }
      });
    });

    observer.observe(document.body, { childList: true, subtree: true });
  })();
</script>
