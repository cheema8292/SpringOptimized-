{{ 'page-banner.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign loading = 'lazy'
  if section.index <= 2
    assign loading = 'eager'
  endif
-%}
<div
  class="page-banner-main-wrapper outer-color-scheme section-spacing"
  {% if section.settings.header_transparent %}
    allow-header-transparent
  {% endif %}
>
  <div class="{{ section.settings.container_width }}">
    <div class="page-banner-wrapper color-scheme {{ section.settings.color_scheme }} color-{{ section.settings.color_type }} d-grid pos-relative{%  if section.settings.rounded_corners == 'all' %} {{ section.settings.rounded_corners_type }}{% endif %}">
      {% if article.image %}
        <div class="page-banner-media width-100 height-100">
          <div
            class="media-card media-fixed media-card-overlay"
            {% if settings.image_animation_type != 'none' %}
              animate-element="true"
              data-animate="{{ settings.image_animation_type }}"
              data-zoom-initial="1.1"
              data-zoom-final="1.0"
              data-zoom-duration="1.5"
              data-zoom-ease="power3.out"
              data-delay="0.3"
            {% endif %}
          >
            {% liquid
              assign image_alt = article.image.alt | default: article.title | escape
              assign fetch_priority = 'auto'
              if loading == 'eager'
                assign fetch_priority = 'high'
              endif
              assign image_sizes = '(max-width: 767px) 100vw, (max-width: 1024px) 100vw, (max-width: 1367px) 100vw, (max-width: 1599px) 100vw, 100vw'
              assign image_widths = '375, 550, 750, 900, 1200, 1500, 1800, 2100, 2400, 2700, 3000, 3600, 3840'
            %}
            {{
              article.image
              | image_url: width: 3840, format: 'webp'
              | image_tag:
                sizes: image_sizes,
                widths: image_widths,
                decoding: 'async',
                loading: loading,
                fetchpriority: fetch_priority,
                class: 'blog-image',
                alt: image_alt
            }}
          </div>
        </div>
      {% endif %}
      <div class="page-banner-content {% if section.settings.container_width == 'container-full' %} {{ section.settings.inner_container_width }}{% endif %}  alignment-{{ section.settings.content_alignment }} {{ section.settings.content_position }}">
        <div class="page-banner-content-inner">
          {%- if section.settings.show_article_published_date
            or section.settings.show_post_author
            or section.settings.show_comment_count
          -%}
            <div class="blog-meta-holder d-inline-flex align-items-center flex-wrap">
              {%- if section.settings.show_article_published_date -%}
                <div class="blog-meta">
                  {% render 'svg-icons',
                    icon_type: 'date',
                    extra_class: 'icon-blog-meta article-date-icon d-inline-flex'
                  %}
                  <span class="article-date">{{ article.published_at | date: '%B %d, %Y' }}</span>
                </div>
              {%- endif -%}
              {%- if section.settings.show_post_author -%}
                <div class="blog-meta">
                  {% render 'svg-icons',
                    icon_type: 'author',
                    extra_class: 'icon-blog-meta article-auth-icon d-inline-flex'
                  %}
                  <span class="article-author" data-auth="{{ article.user.image }}">{{ article.author }}</span>
                </div>
              {%- endif -%}
              {%- if section.settings.show_comment_count -%}
                <div class="blog-meta">
                  {% render 'svg-icons',
                    icon_type: 'blog-comment',
                    extra_class: 'icon-blog-meta article-comment-icon d-inline-flex'
                  %}
                  <span class="article-comment">{{ 'blogs.article.comments' | t: count: article.comments_count }}</span>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
          <{{ section.settings.heading_tag }} class="blog-page-banner-heading heading-font {{ section.settings.heading_size }}">
            {{ article.title | escape }}
          </{{ section.settings.heading_tag }}>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
    #shopify-section-{{ section.id }}{
      --topSpacer: {{ section.settings.top_space_desktop }}px;
      --bottomSpacer:{{ section.settings.bottom_space_desktop }}px;
      --sectionRadius:{{ section.settings.border_radius }}px;
      --outerBackground: {{ section.settings.outer_background }};
      --mediaHeight: {{ section.settings.desktop_custom_height }}px;
      {% if section.settings.enable_overlay %}
        {% if section.settings.overlay_style == 'gradient' %}
          --imageOverlay: {{ section.settings.overlay_gradient }};
        {% else %}
          --imageOverlay: rgba({{ section.settings.overlay_solid.rgba }});
        {% endif %}
      {% endif %}
    }
    @media only screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} {
        --topSpacer: {{ section.settings.top_space_mobile }}px;
        --bottomSpacer: {{ section.settings.bottom_space_mobile }}px;
        --mediaHeight: {{ section.settings.mobile_custom_height }}px;
        {% if section.settings.border_radius > 30 %}
          --sectionRadius: calc({{ section.settings.border_radius }}px / 2);
        {% else %}
          --sectionRadius:{{ section.settings.border_radius }}px;
        {% endif %}
      }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
</style>
{% schema %}
{
  "name": "t:sections.blog-page-banner.name",
  "class": "blog-page-banner-section",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.headers.general"
    },
    {
      "type": "checkbox",
      "id": "header_transparent",
      "label": "t:sections.all.headers.header_transparent.label",
      "default": false,
      "info": "t:sections.all.headers.header_transparent.info"
    },
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:sections.all.settings.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:sections.all.settings.section_visibility.always.label",
          "value": "always"
        },
        {
          "label": "t:sections.all.settings.section_visibility.small_devices.label",
          "value": "small"
        },
        {
          "label": "t:sections.all.settings.section_visibility.large_devices.label",
          "value": "large"
        }
      ]
    },
    {
      "type": "color",
      "id": "outer_background",
      "label": "t:sections.all.settings.outer_background.label",
      "default": "#ffffff"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "t:sections.all.settings.colors.label"
    },
    {
      "type": "select",
      "id": "color_type",
      "label": "t:sections.all.settings.color_background.label",
      "default": "solid",
      "options": [
        {
          "label": "t:sections.all.settings.color_background.options.background_solid",
          "value": "solid"
        },
        {
          "label": "t:sections.all.settings.color_background.options.background_gradiant",
          "value": "gradient"
        }
      ]
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "t:sections.all.settings.container_width.label",
      "default": "container-narrow",
      "options": [
        {
          "label": "t:sections.all.settings.container_width.small.label",
          "value": "container-small"
        },
        {
          "label": "t:sections.all.settings.container_width.standard.label",
          "value": "container"
        },
        {
          "label": "t:sections.all.settings.container_width.container_wide.label",
          "value": "container-wide"
        },
        {
          "label": "t:sections.all.settings.container_width.container_edge.label",
          "value": "container-narrow"
        },
        {
          "label": "t:sections.all.settings.container_width.full_width.label",
          "value": "container-full"
        }
      ]
    },
    {
      "type": "select",
      "id": "inner_container_width",
      "label": "t:sections.all.settings.container_width.inner_container",
      "default": "container-wide",
      "visible_if": "{{ section.settings.container_width == 'container-full' }}",
      "options": [
        {
          "label": "t:sections.all.settings.container_width.small.label",
          "value": "container-small"
        },
        {
          "label": "t:sections.all.settings.container_width.standard.label",
          "value": "container"
        },
        {
          "label": "t:sections.all.settings.container_width.container_wide.label",
          "value": "container-wide"
        },
        {
          "label": "t:sections.all.settings.container_width.container_edge.label",
          "value": "container-narrow"
        }
      ]
    },
    {
      "type": "select",
      "id": "rounded_corners",
      "label": "t:sections.all.settings.rounded_corners.label",
      "options": [
        {
          "label": "t:sections.all.settings.rounded_corners.sharp.label",
          "value": "none"
        },
        {
          "label": "t:sections.all.settings.rounded_corners.rounded.label",
          "value": "all"
        }
      ],
      "default": "all"
    },
    {
      "type": "select",
      "id": "rounded_corners_type",
      "label": "t:sections.all.settings.rounded_corners_type.label",
      "visible_if": "{{ section.settings.rounded_corners == 'all' }}",
      "options": [
        {
          "label": "t:sections.all.settings.rounded_corners_type.option_0.label",
          "value": "layout-rounded-top"
        },
        {
          "label": "t:sections.all.settings.rounded_corners_type.option_1.label",
          "value": "layout-rounded-bottom"
        },
        {
          "label": "t:sections.all.settings.rounded_corners_type.option_2.label",
          "value": "layout-rounded"
        }
      ],
      "default": "layout-rounded"
    },
    {
      "type": "range",
      "id": "border_radius",
      "info": "t:sections.all.settings.card_radius.info",
      "label": "t:sections.all.settings.corner_radius.label",
      "min": 2,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 10,
      "visible_if": "{{ section.settings.rounded_corners == 'all' }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.section_spacing"
    },
    {
      "type": "select",
      "id": "select_type",
      "label": "t:sections.all.settings.section_spacing.choose_from.label",
      "options": [
        {
          "label": "t:sections.all.settings.section_spacing.choose_from.options.desktop.label",
          "value": "desktop"
        },
        {
          "label": "t:sections.all.settings.section_spacing.choose_from.options.mobile.label",
          "value": "mobile"
        }
      ],
      "default": "desktop"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:sections.all.settings.section_spacing.top_spacing.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.select_type == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:sections.all.settings.section_spacing.bottom_spacing.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.select_type == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:sections.all.settings.section_spacing.top_spacing.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.select_type == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:sections.all.settings.section_spacing.bottom_spacing.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.select_type == 'mobile' }}"
    },
    {
      "type": "header",
      "content": "t:sections.page-banner.settings.banner.label"
    },
    {
      "type": "range",
      "id": "desktop_custom_height",
      "label": "t:sections.all.settings.media_height.image_height",
      "min": 200,
      "max": 700,
      "default": 350,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "mobile_custom_height",
      "label": "t:sections.all.settings.media_height.image_height_mob",
      "min": 100,
      "max": 500,
      "default": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "t:sections.all.settings.overlay.header"
    },
    {
      "type": "checkbox",
      "id": "enable_overlay",
      "label": "t:sections.all.settings.overlay.enable_overlay.label",
      "default": false
    },
    {
      "type": "select",
      "id": "overlay_style",
      "label": "t:sections.all.settings.overlay.style.label",
      "options": [
        {
          "label": "t:sections.all.settings.overlay.style.options__0.label",
          "value": "solid"
        },
        {
          "label": "t:sections.all.settings.overlay.style.options__1.label",
          "value": "gradient"
        }
      ],
      "default": "solid"
    },
    {
      "type": "color_background",
      "id": "overlay_gradient",
      "label": "t:sections.all.settings.overlay.color.label",
      "default": "linear-gradient(0deg, rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.04) 100%)",
      "visible_if": "{{ section.settings.overlay_style == 'gradient' }}"
    },
    {
      "type": "color",
      "id": "overlay_solid",
      "label": "t:sections.all.settings.overlay.color.label",
      "alpha": true,
      "default": "#00000093",
      "visible_if": "{{ section.settings.overlay_style == 'solid' }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.content"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.all.settings.heading_tag.label",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        },
        {
          "value": "div",
          "label": "Div"
        },
        {
          "value": "span",
          "label": "Span"
        },
        {
          "value": "p",
          "label": "P"
        }
      ],
      "default": "h6"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.all.settings.heading_size.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.settings.heading_size.options.heading_xl"
        },
        {
          "value": "h2",
          "label": "t:sections.all.settings.heading_size.options.heading_l"
        },
        {
          "value": "h3",
          "label": "t:sections.all.settings.heading_size.options.heading_m"
        },
        {
          "value": "h4",
          "label": "t:sections.all.settings.heading_size.options.heading_s"
        },
        {
          "value": "h5",
          "label": "t:sections.all.settings.heading_size.options.heading_xs"
        },
        {
          "value": "h6",
          "label": "t:sections.all.settings.heading_size.options.heading_xxs"
        }
      ],
      "default": "h6"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "t:sections.all.settings.vertical_alignment.label",
      "default": "align-items-center",
      "options": [
        { 
          "label": "t:sections.all.settings.vertical_alignment.option_1", 
          "value": "align-items-start" 
        },
        { 
          "label": "t:sections.all.settings.vertical_alignment.option_2", 
          "value": "align-items-center" 
        },
        { 
          "label": "t:sections.all.settings.vertical_alignment.option_3", 
          "value": "align-items-end" 
        }
      ]
    },
    {
      "type": "text_alignment",
      "id": "content_alignment",
      "label": "t:sections.all.settings.text_alignment.label",
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "show_article_published_date",
      "label": "t:sections.blog-posts.settings.show_article_published_date.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_post_author",
      "label": "t:sections.blog-posts.settings.show_post_author.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_comment_count",
      "label": "t:sections.blog-posts.settings.show_comment_count.label",
      "default": false
    }
  ]
}
{% endschema %}
