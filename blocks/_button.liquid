<style>
  #shopify-block-{{block.id}}{
    --buttonBackground: rgba({{ block.settings.button_color.rgba }});
    --buttonColor: rgba({{ block.settings.button_text_color.rgba }});
    --buttonBorder:rgba({{ block.settings.button_color.rgba }});
    --buttonBackgroundHover: rgba({{ block.settings.button_hover_color.rgba }});
    --buttonColorHover:rgba({{ block.settings.button_text_hover_color.rgba }});
    --buttonBorderHover:rgba({{ block.settings.button_hover_color.rgba }});
    --buttonBorder:rgba({{ block.settings.button_border_color.rgba }});
    --buttonBorderHover:rgba({{ block.settings.button_hover_border_color.rgba }});
  }
  #shopify-block-{{block.id}} .button-underline{
    --textColor:{{ block.settings.button_text_color }}
  }
</style>

{% if block.settings.button_text != blank %}
  {% comment %} /*  added condition to add div if anchor tag is not added */ {% endcomment %}
  {% if block.settings.button_url != blank %}
    <a
      href="{{ block.settings.button_url }}" class="button content-btn {% if block.settings.set_button_as_link %}button-underline{% endif %}" {% if block.settings.is_open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
    content-btn
        >
      <span class="button-text">{{ block.settings.button_text }}</span>
      <span class="button-icon">
        {% render 'svg-icons', icon_type: 'arrow-right' %}
      </span>
    </a>
  {% else %}
    <div
      class="button content-btn {% if block.settings.set_button_as_link %}button-underline{% endif %}"
      aria-disabled="true"
      role="button"
      content-btn
    >
      <span class="button-text">{{ block.settings.button_text }}</span>
      <span class="button-icon">
        {% render 'svg-icons', icon_type: 'arrow-right' %}
      </span>
    </div>
  {% endif %}
{% endif %}

{% schema %}
{
  "name": "t:sections.all.headers.button", 
  "class":"button-block",
  "settings": [
    {
      "type": "text",
      "id": "button_text",
      "label": "t:sections.all.settings.button.label",
      "default": "Button text"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:sections.all.settings.button.link"
    },
    {
      "type": "checkbox",
      "label": "t:sections.all.settings.button.is_open_in_new_tab",
      "id": "is_open_in_new_tab",
      "default": false
    },
    {
      "type": "checkbox",
      "label": "t:sections.all.settings.button.set_button_as_link",
      "id": "set_button_as_link",
      "default": false
    },
    {
      "type": "header",
      "content":"t:sections.all.settings.commom_colors.header"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "t:sections.all.settings.commom_colors.settings.background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "t:sections.all.settings.commom_colors.settings.text",
      "default": "#ffffff"
    },
    {
       "type": "color",
      "id": "button_border_color",
      "label": "t:sections.all.settings.commom_colors.settings.border",
      "default": "#ffffff"

    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "t:sections.all.settings.commom_colors.settings.background_hover",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_hover_color",
      "label": "t:sections.all.settings.commom_colors.settings.text_hover",
      "default": "#ffffff"
    }, 
    {
       "type": "color",
      "id": "button_hover_border_color",
      "label": "t:sections.all.settings.commom_colors.settings.border_hover",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "t:sections.all.headers.button",
      "category": "Basic"

    }
  ]
}
{% endschema %}
