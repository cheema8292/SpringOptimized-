{{ 'custom-grid.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign show_overlap_content = false
  if section.settings.show_behind_sections_below
    if section.settings.background_image != blank
      assign show_overlap_content = true
    endif
  endif
-%}
{%- if show_overlap_content -%} 
<overlap-content 
  class="d-block{% if section.settings.rounded_corners == 'all' %} {{ section.settings.rounded_corners_type }}{% endif %}" 
  {% if section.settings.show_behind_sections_below %}data-count-below="1"{% endif %}
  style="--overlap-content-top: 0px; --overlap-content-bottom: 0px;"
 >
{%- endif -%}
<div class="color-scheme section-spacing {{ section.settings.color_scheme }} color-{{ section.settings.color_type }}{% if section.settings.background_image != blank %} pos-relative{% endif %}" id="{{ section.id }}">
  {%- if show_overlap_content -%}
    <div class="background-image-outer">
  {%- endif -%}

  {% if section.settings.background_image != blank %}
    <div class="background-image{% if section.settings.enable_overlay %} media-card-overlay{% endif %}">
      {{ section.settings.background_image
        | image_url: width: 3840, format: 'webp'
        | image_tag:
            widths: '360, 540, 720, 960, 1200, 1600, 1920, 2560, 3200, 3840',
            sizes: '100vw',
            loading: 'eager',
            decoding: 'async',
            class: 'background-media-image'
      }}
    </div>
  {% endif %}
  
  <div class="{{ section.settings.container_width }} {% if section.settings.enable_mobile_swipe %}m-pr-0{% endif %}">
    <div class="custom-grid-wrapper {% if section.settings.enable_mobile_swipe %}mobile-swipe mobile-column-1{% endif %}">
      {% content_for 'blocks' %}
    </div>
  </div>

  {%- if show_overlap_content -%}
  </div>
  {%- endif -%}

</div>
{%- if show_overlap_content -%}
</overlap-content>
{%- endif -%}

<style>
  #shopify-section-{{ section.id }}{
    --topSpacer: {{ section.settings.top_space_desktop }}px;
    --bottomSpacer:{{ section.settings.bottom_space_desktop }}px;
    --columnGap : {{ section.settings.desktop_column_gap }}px;
    --desktopHeight : {{ section.settings.desktop_row_height }}px;
    --blockRadius :{{ section.settings.border_radius }}px;
    --sectionRadius:{{ section.settings.border_radius_overlaped_content }}px;
  }
  {% if section.settings.enable_overlay and section.settings.background_image != blank %}
    #shopify-section-{{ section.id }} .background-image {
      {% if section.settings.overlay_style == 'gradient' %}
        --imageOverlay: {{ section.settings.overlay_gradient }};
      {% else %}
        --imageOverlay: rgba({{ section.settings.overlay_solid.rgba }});
      {% endif %}
    }
  {% endif %}

  {% if show_overlap_content %}
    overlap-content:has(#{{ section.id }}) .background-image-outer {
      padding-bottom: var(--overlap-content-bottom);
    }
    overlap-content {
      margin-bottom: calc(-1 * var(--overlap-content-bottom));
    }
  {% endif %}

  {% if section.blocks.size > 0 %}
    {% for block in section.blocks %}
      #media-grid-itm-{{block.id}} {
        --row:{{ block.settings.desktop_row }};
        --column:{{ block.settings.desktop_column }};
      }
    {% endfor %}
  {% endif %}
  @media only screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      --topSpacer: {{ section.settings.top_space_mobile }}px;
      --bottomSpacer: {{ section.settings.bottom_space_mobile }}px;
      --mobileHeight : {{ section.settings.mobile_row_height }}px;
      {% if section.settings.border_radius > 20 %}
        --blockRadius: calc( {{ section.settings.border_radius }}px / 2);
      {% else %}
        --blockRadius: {{ section.settings.border_radius }}px ;
      {% endif %}
      {% if section.settings.border_radius_overlaped_content > 30 %}
        --sectionRadius: calc({{ section.settings.border_radius_overlaped_content }}px / 2);
      {% else %}
         --sectionRadius:{{ section.settings.border_radius_overlaped_content }}px;
      {% endif %}
    }
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        #media-grid-itm-{{block.id}}{
          --row:{{ block.settings.mobile_row }};
          --column:{{ block.settings.mobile_column }};
        }
      {% endfor %}
    {% endif %}
  }
  {% if section.settings.section_visibility == 'large' %}
    @media(max-width: 767px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
</style>
{%- if show_overlap_content -%}
  <script src="{{ 'overlap-content.js' | asset_url }}" defer></script>
{%- endif -%}
