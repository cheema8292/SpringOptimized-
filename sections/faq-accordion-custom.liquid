{% schema %}
{
  "name": "FAQ Accordion (Custom)",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width (px)",
      "min": 800,
      "max": 1600,
      "step": 50,
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 20,
      "max": 120,
      "step": 5,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 20,
      "max": 120,
      "step": 5,
      "default": 60
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accordion_bg",
      "label": "Accordion question background",
      "default": "#00a99d"
    },
    {
      "type": "color",
      "id": "accordion_text",
      "label": "Accordion question text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "answer_text",
      "label": "Answer text color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size (px)",
      "min": 24,
      "max": 56,
      "step": 2,
      "default": 40
    },
    {
      "type": "range",
      "id": "question_size",
      "label": "Question font size (px)",
      "min": 14,
      "max": 24,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "answer_size",
      "label": "Answer font size (px)",
      "min": 14,
      "max": 22,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Accordion border radius (px)",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 6
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Are the glasses dishwasher safe?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Accordion (Custom)",
      "blocks": [
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" }
      ]
    }
  ]
}
{% endschema %}

<section
  class="faq-accordion"
  style="
    background: {{ section.settings.section_bg }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div
    class="faq-wrapper"
    style="max-width: {{ section.settings.max_width }}px;"
  >
    <h2
      class="faq-heading"
      style="font-size: {{ section.settings.heading_size }}px;"
    >
      {{ section.settings.heading }}
    </h2>

    <div class="faq-items">
      {% for block in section.blocks %}
        <div class="faq-item">
          <button
            class="faq-question"
            aria-expanded="false"
            style="
              background: {{ section.settings.accordion_bg }};
              color: {{ section.settings.accordion_text }};
              font-size: {{ section.settings.question_size }}px;
              border-radius: {{ section.settings.border_radius }}px;
            "
          >
            <span>{{ block.settings.question }}</span>
            <span class="faq-icon">›</span>
          </button>

          <div class="faq-answer" style="font-size: {{ section.settings.answer_size }}px; color: {{ section.settings.answer_text }};">
            {{ block.settings.answer }}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
    @media (max-width: 749px){
    .faq-heading{
    font-size: 32px!important;}
    }
.faq-wrapper {
  margin: 0 auto;
  padding: 0 20px;
}

.faq-heading {
  text-align: center;
  font-weight: 600;
  margin-bottom: 40px;
}

.faq-item + .faq-item {
  margin-top: 16px;
}

.faq-question {
  width: 100%;
  padding: 16px 20px;
  border: none;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  text-align: left;
  font-weight: 700;
}

.faq-icon {
  font-size: 20px;
  transition: transform 0.3s ease;
}

.faq-question[aria-expanded="true"] .faq-icon {
  transform: rotate(90deg);
}

.faq-answer {
  max-height: 0;
  overflow: hidden;
  background: #ffffff;
  padding: 0 20px;
  transition: max-height 0.35s ease, padding 0.35s ease;
}

.faq-question[aria-expanded="true"] + .faq-answer {
  max-height: 500px;
  padding: 16px 20px 24px;
}

@media (max-width: 768px) {
  .faq-heading {
    font-size: calc({{ section.settings.heading_size }}px - 8px);
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.faq-question').forEach(button => {
    button.addEventListener('click', () => {
      const expanded = button.getAttribute('aria-expanded') === 'true';
      button.setAttribute('aria-expanded', !expanded);
    });
  });
});
</script>
