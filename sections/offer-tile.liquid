{{ 'offer-tile.css' | asset_url | stylesheet_tag }}
{% liquid
  assign loading = 'lazy'
  assign fetch_priority = 'auto'
  if section.index <= 2
    assign loading = 'eager'
    assign fetch_priority = 'high'
  endif
  assign default_alt = 'Offer tile image' | escape
%}
<div class="outer-color-scheme section-spacing">
  <div class="{{ section.settings.container_width }}">
    <div class="offer-tile-wrapper-main color-scheme {{ section.settings.color_scheme }} color-{{ section.settings.color_type }} {%  if section.settings.rounded_corners == 'all' %} {{ section.settings.rounded_corners_type }}{% endif %}">
      <div class="offer-tile-wrapper">
        {% if section.settings.image_picker != blank %}
          <div class="offer-tile-media">
            <div class="media-card media-fixed media-card-overlay d-none md-block">
              {% assign image_alt = section.settings.image_picker.alt | default: default_alt %}
              {{
                section.settings.image_picker
                | image_url: width: 3840, format: 'webp'
                | image_tag:
                  sizes: '(max-width: 479px) 100vw, (max-width: 767px) 100vw, (max-width: 1023px) 100vw, 100vw',
                  widths: '180, 240, 320, 375, 480, 600, 768, 900, 1024, 1280, 1600, 1920, 2560, 3840',
                  decoding: 'async',
                  loading: loading,
                  fetchpriority: fetch_priority,
                  alt: image_alt
              }}
            </div>
            {% liquid
              assign mobile_image = section.settings.mobile_image_picker | default: section.settings.image_picker
            %}
            <div class="media-card media-fixed media-card-overlay d-block md-none">
              {% assign image_alt = mobile_image.alt | default: default_alt %}
              {{
                mobile_image
                | image_url: width: 1280, format: 'webp'
                | image_tag:
                  sizes: '(max-width: 767px) 100vw',
                  widths: '375, 480, 600, 768, 900, 1024, 1280',
                  decoding: 'async',
                  loading: loading,
                  fetchpriority: fetch_priority,
                  alt: image_alt
              }}
            </div>
          </div>
        {% endif %}
        <div class="offer-tile-content  {% if section.settings.container_width == 'container-full' %} {{ section.settings.inner_container_width }}  {% endif %}">
          <div class="offer-tile-left">
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'divider' %}
                  <span class="offer-tile-divider"></span>
              {% endcase %}
            {% endfor %}
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'heading' %}
                  {% liquid
                    assign highlight_text_class = ''
                    assign plain_text = block.settings.text | strip_newlines | strip_html | strip
                    assign highlight_text_setting = block.settings.highlight_text
                    assign highlight_text_font = block.settings.highlight_font
                    if highlight_text_setting == 'underline'
                      assign highlight_text_class = 'text-underline'
                    elsif highlight_text_setting == 'color'
                      assign highlight_text_class = 'text-highlight-color'
                    elsif highlight_text_setting == 'gradiant'
                      assign highlight_text_class = 'text-highlight-gradiant'
                    endif
                    assign highlight_start = '<span class="text-highlight ' | append: highlight_text_class | append: ' ' | append: highlight_text_font | append: '">'
                    assign highlight_end = '</span>'
                  %}
                  {% if plain_text != blank %}
                    <{{ block.settings.type_preset }}
                      class="offer-tile-heading heading-font heading-color {{ block.settings.heading_size }}"
                      {{ block.shopify_attributes }}
                      {% if settings.enable_heading_transition %}
                        animate-element="true" data-animate="{{ settings.heading_animation_type }}"
                      {% endif %}
                    >
                      {{
                        block.settings.text
                        | replace: '[', highlight_start
                        | replace: ']', highlight_end
                        | replace: '++', '<br/>'
                        | replace: '<a', '<a class="text-underline"'
                        | newline_to_br
                      }}
                    </{{ block.settings.type_preset }}>
                  {% endif %}
                {% when 'subheading' %}
                  {% if block.settings.subheading != blank %}
                    <div class="offer-tile-subheading heading-font heading-color text-xlarge">
                      {{ block.settings.subheading }}
                    </div>
                  {% endif %}
              {% endcase %}
            {% endfor %}
          </div>
          <div class="offer-tile-right">
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'description' %}
                  {% if block.settings.description != blank %}
                    <p class="offer-tile-desc {{ block.settings.description_size }}">
                      {{ block.settings.description }}
                    </p>
                  {% endif %}
                {% when 'button' %}
                  {% if block.settings.button_text != blank %}
                    <div class="offer-tile-button">
                      {% render 'button-appearance',
                        button_text: block.settings.button_text,
                        button_url: block.settings.button_url,
                        button_style: block.settings.button_style,
                        is_open_in_new_tab: block.settings.is_open_in_new_tab,
                        class: ''
                      %}
                    </div>
                  {% endif %}
              {% endcase %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
    #shopify-section-{{ section.id }} {
     --topSpacer: {{ section.settings.top_space_desktop }}px;
     --bottomSpacer:{{ section.settings.bottom_space_desktop }}px;
     --mediaHeight:{{ section.settings.desktop_height }}px;
     --sectionRadius:{{ section.settings.border_radius }}px;
     --outerBackground: {{ section.settings.outer_background }};
     {% if section.settings.enable_overlay %}
        {% if section.settings.overlay_style == 'gradient' %}
          --imageOverlay: {{ section.settings.overlay_gradient }};
        {% else %}
          --imageOverlay: rgba({{ section.settings.overlay_solid.rgba }});
        {% endif %}
      {% endif %}
    }

       #shopify-section-{{ section.id }}  .text-highlight-color{
        {%  for block in section.blocks %}
        {% if block.type == 'heading' %}
          --highlightColor:{{ block.settings.text_color }};
          {% endif %}
          {% endfor %}
                }
   #shopify-section-{{ section.id }} .text-highlight-gradiant{
    {%  for block in section.blocks %}
        {% if block.type == 'heading' %}
      --highlightColor:{{ block.settings.gradiant_color }};
        {% endif %}
          {% endfor %}
    }

    @media only screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} {
        --topSpacer: {{ section.settings.top_space_mobile }}px;
        --bottomSpacer: {{ section.settings.bottom_space_mobile }}px;
     --mediaHeight:{{ section.settings.mobile_height }}px;
        {% if section.settings.media_radius > 20 %}
          --blockRadius: calc( {{ section.settings.media_radius }}px / 2);
        {% else %}
          --blockRadius: {{ section.settings.media_radius }}px ;
        {% endif %}
      }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "Offer tile",
  "class": "offer-tile-section",
  "tag": "section",
  "blocks": [
    {
      "name": "Heading",
      "type": "heading",
      "limit": 1,
      "settings": [
