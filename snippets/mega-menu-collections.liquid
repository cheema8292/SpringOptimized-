
<div class="mega-menu-wrapper mega-menu-collections">
  <div class="mega-menu-container">
    <mega-menu-collection class="mega-menu-sidebar-wrapper">
      <div class="mega-menu-sidebar">
        <p class="heading-font h6 mega-menu-collections-heading" >{{ block.settings.text }}</p>
        <ul>
          {% for collection in block.settings.collection_list %}      
            {% if collection.all_products_count > 0 %}
              <li><a href="{{ collection.url }}" class="mega-menu-sidebar-link {{ settings.header_second_level_menus_size }} {{ settings.header_second_level_menus_font }}-font {%  if forloop.first %}active{% endif %}" tab-menu >{{ collection.title }}</a></li>
            {% endif %}   
          {% endfor %}
        </ul>
        {% if block.settings.button_text != blank %}
          <div class="mega-menu-sidebar-btn">
            {% render 'button-appearance', button_text: block.settings.button_text, button_url: block.settings.button_link_to, button_style: block.settings.button_style, is_open_in_new_tab:false, extra_attribute:'' %}
          </div>
        {% endif %}
      </div>
      <div class="mega-menu-sidebar-content">
      {% for collection in block.settings.collection_list %}
            {% if collection.all_products_count > 0 %}
        {% liquid
         assign grid_count = 3
          assign has_slider = false
          if collection.all_products_count.size > block.settings.desktop_column_count and block.settings.max_products_to_show > grid_count
          assign has_slider = true
          else 
          assign has_slider = false
          endif
        %}
          <div class="mega-menu-sidebar-content-inner {% if has_slider %}swiper{% endif %} {%  if forloop.first %}active{% endif %}" tab-content 
           {% if has_slider %}
          data-swiper='
            {
              "loop": false,
              "autoHeight": false,
              "speed":1000,
              "slidesPerView": 1.3,
              "spaceBetween": 10,
              "breakpoints": {
                  "768": {
                    "slidesPerView": {% if block.settings.desktop_column_count  <= 2 %}{{ block.settings.desktop_column_count }}{% else %}3{% endif %}
                  },
                  "1025": {
                        "slidesPerView": {% if block.settings.desktop_column_count  <= 3 %}{{ block.settings.desktop_column_count }}{% else %}4{% endif %}
                  },
                  "1280": {
                    "slidesPerView": {{ block.settings.desktop_column_count }}
                  }
                },
              "centeredSlides": false
            }
          '
        {% endif %}
          >
          {% if has_slider %}
            <div class="swiper-wrapper slides-equal-height">
              {% endif %}
            {% if collection.products.size > 0 %}    
              {% for product in collection.products limit: block.settings.max_products_to_show %}
                <div class="{% if has_slider %}swiper-slide{% endif %}">
                 {% render 'product-card', product_card: product,section: block, aspect_ratio_image: block.settings.aspect_ratio %}
                </div>  
              {% endfor %}
            {% endif %}
            {% if has_slider %}
          </div>
          {% endif %}
          </div>
        {% endif %}
        {% endfor %}
      </div>
    </mega-menu-collection>
  </div>
</div>
<style>
 .mega-menu-collections {
    {% if block.settings.desktop_column_count <= 2 %}
      --columnCount: {{ block.settings.desktop_column_count }};
    {% else %} 
      --columnCount: 3;
    {% endif %}
  }

  @media (min-width:1025px) {
   .mega-menu-collections{
      {% if block.settings.desktop_column_count <= 3 %}
        --columnCount: {{ block.settings.desktop_column_count }};
      {% else %}
        --columnCount: 4;
      {% endif %}
    }
  }
  @media (min-width:1280px) {
   .mega-menu-collections {
      --columnCount: {{ block.settings.desktop_column_count }};
    }
  }
  
</style>
<script src="{{ 'mega-menu-collections.js' | asset_url }}" defer="defer"></script> 