<style>
  .mobile-menu-submenu{
    --overlayTextColor:{{ block.settings.promo_color_text }};
  {% if block.settings.enable_overlay %}
      {% if block.overlay_style == 'gradient' %}
        --imageOverlay: {{ block.settings.overlay_gradient }};
      {% else %}
        --imageOverlay: rgba({{ block.settings.overlay_solid.rgba }});
      {% endif %}
    {% endif %}
  }
</style>
<div class="mobile-menu-submenu height-100 mobile-image-mega-menu">
  <div class="mobile-menu-submenu-back" data-back-to-menu>
    <button aria-label="Back">
      {% render 'svg-icons', icon_type: 'angle-left' %}
    </button>
    <span class="{{ settings.header_second_level_menus_size }} {{ settings.header_second_level_menus_font }}-font">
      {{ link.title }}
    </span>
  </div>
  <div class="mobile-submenu-box">
    <ul class="mobile-submenu-list">
      {% for innerLink in link.links %}
        {% liquid
          assign is_inner_chlid_menu = false
          if innerLink.links.size > 0
            assign is_inner_chlid_menu = true
          endif
        %}
        <li
          class="mobile-menu-item"
          {% if is_inner_chlid_menu %}
            data-menu-item
          {% endif %}
        >
          {% if is_inner_chlid_menu %}
            <details class="mobile-menu-item-inner">
              <summary class="mobile-image-mega-menu-heading">
                <span
                  class="mobile-menu-link {{ settings.header_second_level_menus_size }} {{ settings.header_second_level_menus_font }}-font"
                >
                  {{- innerLink.title }}
                  {% if innerLink.links.size > 0 %}
                    {% render 'svg-icons', icon_type: 'angle-down' %}
                  {% endif -%}
                </span>
              </summary>
              {% if innerLink.links.size > 0 %}
                <div class="mobile-image-inner-mega-menu inner-submenu height-100">
                  <ul class="mobile-submenu-list inner-submenu-list">
                    {% for innerChildLink in innerLink.links %}
                      <li class="mobile-menu-item">
                        <a
                          href="{{ innerChildLink.url }}"
                          class="mobile-menu-link {{ settings.header_third_level_menus_size }} {{ settings.header_third_level_menus_font }}-font"
                        >
                          {{- innerChildLink.title }}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              {% endif -%}
            </details>
          {% else %}
            <a
              href="{{ innerLink.url }}"
              class="mobile-menu-link {{ settings.header_second_level_menus_size }} {{ settings.header_second_level_menus_font }}-font"
            >
              {{- innerLink.title -}}
            </a>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
    {% if block.settings.promo_image_1 != blank or block.settings.promo_image_2 != blank %}
      <div class="mobile-mega-menu-promo mobile-stacked mobile-swipe mobile-column-1">
        {% if block.settings.promo_image_1 != blank %}
          {% if block.settings.promo_link_1 != blank %}
            <a href="{{ block.settings.promo_link_1 }}" class="header-promotion-banner-item">
          {% else %}
            <div class="header-promotion-banner-item test3">
          {% endif %}
          <div class="header-promotion-banner-media">
            <div class="media-card media-adapt media-card-overlay testing" style="--imageRatio:1;">
              {% if block.settings.image_custom != blank %}
                {% liquid
                  assign image_alt = block.settings.image_custom.alt | default: 'Mega menu' | escape
                  assign image_sizes = '(max-width: 600px) 100vw, 540px'
                  assign image_widths = '180,360,540'
                %}
                {{
                  block.settings.image_custom
                  | image_url: width: 540, format: 'webp'
                  | image_tag:
                    sizes: image_sizes,
                    widths: image_widths,
                    decoding: 'async',
                    loading: 'lazy',
                    fetchpriority: 'auto',
                    alt: image_alt
                }}
              {% endif %}
              {% liquid
                assign image_alt = block.settings.promo_image_1.alt | default: 'Mega menu' | escape
                assign image_sizes = '(max-width: 600px) 100vw, 540px'
                assign image_widths = '180,360,540'
              %}
              {{
                block.settings.promo_image_1
                | image_url: width: 540, format: 'webp'
                | image_tag:
                  sizes: image_sizes,
                  widths: image_widths,
                  decoding: 'async',
                  loading: 'lazy',
                  fetchpriority: 'auto',
                  class: 'mobile-promotion-media-image',
                  alt: image_alt
              }}
            </div>
            {%- if block.settings.promo_heading_1 != blank or block.settings.promo_description_1 != blank -%}
              <div class="header-promotion-banner-content-wrapper">
                {%- if block.settings.promo_heading_1 != blank -%}
                  <h6 class="header-promotion-banner-heading overlay-text {{ block.settings.promo_heading_1_heading_size }}">
                    {{ block.settings.promo_heading_1 }}
                  </h6>
                {%- endif -%}
                {%- if block.settings.promo_description_1 != blank -%}
                  <p class="header-promotion-banner-desc overlay-text {{ block.settings.promo_heading_1_description_size }}">
                    {{ block.settings.promo_description_1 }}
                  </p>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
          {% if block.settings.promo_link_1 != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        {% endif %}
        {% if block.settings.promo_image_2 != blank %}
          {% if block.settings.promo_link_2 != blank %}
            <a href="{{ block.settings.promo_link_2 }}" class="header-promotion-banner-item">
          {% else %}
            <div class="header-promotion-banner-item">
          {% endif %}
          <div class="header-promotion-banner-media">
            <div class="media-card media-adapt media-card-overlay test6" style="--imageRatio:1;">
              {% liquid
                assign default_alt = 'Mobile image mega menu'
                assign image_alt = block.settings.promo_image_2.alt | default: default_alt
                assign image_sizes = "(max-width: 480px) 80vw, (max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
                assign image_widths = '180, 360, 540, 720, 900, 1080'
              %}
              {{
                block.settings.promo_image_2
                | image_url: width: 1080, format: 'webp'
                | image_tag:
                  sizes: image_sizes,
                  widths: image_widths,
                  decoding: 'async',
                  loading: 'lazy',
                  fetchpriority: 'auto',
                  class: 'mobile-promotion-media-image',
                  alt: image_alt
              }}
            </div>
          </div>
          {%- if block.settings.promo_heading_2 != blank or block.settings.promo_description_2 != blank -%}
            <div class="header-promotion-banner-content-wrapper">
              {%- if block.settings.promo_heading_2 != blank -%}
                <h6 class="header-promotion-banner-heading overlay-text {{ block.settings.promo_heading_2_heading_size }}">
                  {{ block.settings.promo_heading_2 }}
                </h6>
              {%- endif -%}
              {%- if block.settings.promo_description_2 != blank -%}
                <p class="header-promotion-banner-desc overlay-text {{ block.settings.promo_heading_2_description_size }}">
                  {{ block.settings.promo_description_2 }}
                </p>
              {%- endif -%}
            </div>
          {%- endif -%}
          {% if block.settings.promo_link_2 != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>
