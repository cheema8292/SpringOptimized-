{{ 'product-specification.css' | asset_url | stylesheet_tag }}
{% liquid
  assign loading = 'lazy'
  assign fetch_priority = 'auto'
  if section.index <= 3
    assign loading = 'eager'
    assign fetch_priority = 'high'
  endif
%}
<div class="color-scheme {{ section.settings.color_scheme }} color-{{ section.settings.color_type }} section-spacing">
  {% render 'section-id-clipboard', section: section %}
  <div class="{{ section.settings.container_width }}">
    <div class="product-specification-main">
      {% assign text_alignment = 'text-' | append: section.settings.content_alignment %}
      {% capture description_data %}
        {% if section.settings.description != blank %}<p class="section-description {{ section.settings.description_size }}">{{ section.settings.description | newline_to_br }}</p>{% endif %}
        {% endcapture %}
      {% render 'section-heading',
        section_heading_tag: section.settings.heading_tag,
        section_heading_size: section.settings.heading_size,
        section_heading_content: section.settings.heading,
        section_heading_highlight_text: section.settings.highlight_text,
        section_heading_highlight_font: section.settings.highlight_font,
        section_extra_classes: text_alignment,
        extra_html_content: description_data
      %}
      <div class="product-specification-wrapper border image-{{ section.settings.image_placement }}{% if section.settings.rounded_corners == "all" %} {{ section.settings.rounded_corners_type }}{% endif %}">
        <div class="product-specification-image media-wrapper {% if section.settings.rounded_corners == "all" %} {{ section.settings.rounded_corners_type }}{% endif %}">
          <div class="media-card media-adapt" style="--imageRatio:1/1">
            {% liquid
              assign default_alt = product.title | escape
              assign product_image_alt = product.featured_image.alt | default: default_alt
            %}
            {{ product.featured_image | image_url: width: 2560, format: 'webp' | image_tag:
              sizes: '(max-width: 767px) 100vw, (max-width: 1024px) 100vw, (max-width: 1367px) 100vw, (max-width: 1599px) 100vw, 100vw',
              widths: '180, 240, 320, 375, 480, 600, 768, 900, 1024, 1280, 1600, 1920, 2560',
              decoding: 'async',
              loading: loading,
              fetchpriority: fetch_priority,
              alt: product_image_alt
            }}
          </div>
        </div>
        <div class="product-specification-content ">
          <div class="product-specification-item-list">
            {%- for block in section.blocks -%}
              {%- if block.settings.key_title != blank and block.settings.key_value != blank -%}
                <div class="product-specification-item" {{ block.shopify_attributes }}>
                  <div class="product-specification-item-title heading-font text">{{ block.settings.key_title }}</div>
                  {%- if block.settings.key_value != blank -%}
                    <div class="product-specification-item-desc text">{{ block.settings.key_value }}</div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  #shopify-section-{{ section.id }} {
    --topSpacer: {{ section.settings.top_space_desktop }}px;
    --bottomSpacer:{{ section.settings.bottom_space_desktop }}px;
    --sectionRadius:{{ section.settings.border_radius }}px;
  }
  {% if section.settings.highlight_text == 'color' %}
    #shopify-section-{{ section.id }} .text-highlight-color {
      --highlightColor: {{ section.settings.text_color }};
    }
  {% elsif section.settings.highlight_text == 'gradiant' %}
    #shopify-section-{{ section.id }} .text-highlight-gradiant{
      --highlightColor:{{ section.settings.gradiant_color }};
    }
  {% endif %}
  @media only screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      --topSpacer: {{ section.settings.top_space_mobile }}px;
      --bottomSpacer: {{ section.settings.bottom_space_mobile }}px;
      {% if section.settings.border_radius > 30 %}
        --sectionRadius: calc({{ section.settings.border_radius }}px / 2);
      {% else %}
         --sectionRadius:{{ section.settings.border_radius }}px;
      {% endif %}
    }
  }
  {% if section.settings.section_visibility == 'large' %}
    @media(max-width: 767px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
</style>
