<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}" color-mode="light">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}


    {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}
{% render 'navidium-scripts' %}
    {% render 'meta-tags' %}
    <script src="{{ 'foundation.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'constants.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'pubsub.js' | asset_url }}" defer="defer"></script>
    {{ content_for_header }}
    {% render 'global-style-variables' %}
    {{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag: preload: true }}
    {%- comment -%} Photoswipe styles only power the click-to-open product lightbox, so load them off the critical path instead of blocking first paint / competing with the LCP hero. {%- endcomment -%}
    <link rel="stylesheet" href="{{ 'photoswipe.min.css' | asset_url }}" media="print" onload="this.media='all'">
    <noscript>{{ 'photoswipe.min.css' | asset_url | stylesheet_tag }}</noscript>
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'common.css' | asset_url | stylesheet_tag }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    {% comment %} performance changes {% endcomment %}
     {{ 'collection-list.css' | asset_url | stylesheet_tag }}
    {%- unless settings.type_body_font.system? -%}
      <link rel="preload" as="font" href="{{ settings.type_body_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}
    {%- unless settings.type_header_font.system? -%}
      <link rel="preload" as="font" href="{{ settings.type_header_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}
    {%- unless settings.type_accent_font.system? -%}
      <link rel="preload" as="font" href="{{ settings.type_accent_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}
    {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
      <script src="{{ 'localization-form.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
    {% render 'global-js-dependencies' %}
    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      {% if settings.enable_color_mode %}
        const savedMode = localStorage.getItem("color-mode") || "light";
        document.documentElement.setAttribute("color-mode", savedMode);
      {% endif %}
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>
    {% render 'rapid-search-settings' %}
        
</head>
  <body class="">
    {% render 'amp-edits' %}
    
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ 'accessibility.skip_to_text' | t }}
    </a>
    {% if settings.enable_page_transition %}
      {% render 'loading-bar' %} 
    {% endif %}
    {% sections 'header-group' %}
    <main id="MainContent" class="content-for-layout focus-none" role="main">
      {{ content_for_layout }}
    </main>
    {% sections 'footer-group' %}
    {% sections 'overlay-group' %}
    {% if settings.cart_type == "drawer" or settings.cart_type == "notification"  %}
     {% render 'cart-drawer' %}
    {% endif %} 
    <ul hidden> 
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul> 
    {% liquid 
      assign show_cartjs = false
      if settings.cart_type == 'drawer' and request.page_type != 'cart'
        assign show_cartjs = true
      elsif settings.cart_type == 'notification' and request.page_type != 'cart'
        assign show_cartjs = true
      endif
    %} 
    {%- if show_cartjs -%}
      <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
      <script src="{{ 'cart-drawer.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
    {%- if settings.cart_type == 'notification' and request.page_type != 'cart' -%}
      <script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>
      {% render 'cart-notification' %}
    {%- endif -%}
      <script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
    {%- if settings.enable_country_selector or settings.enable_language_selector -%}
      {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
        {% render 'localization-popup' %}
      {%- endif -%}
    {%- endif -%}
    {% if settings.enable_scroll_to_top %}
      {% render 'scroll-to-top',
         horizontal_position:settings.scroll_to_top_horizontal_position,
         vertical_position:settings.scroll_to_top_vertical_position,
         background_color:settings.stp_background_color,
         icon_color:settings.stp_icon_color,
         border_color:settings.stp_border_color,
       %}
    {% endif %}
{% if template contains 'collection' or template contains 'index' %}
      <script>
window.addEventListener('DOMContentLoaded', (event) => {
    const idle = window.requestIdleCallback || ((cb) => setTimeout(cb, 1));
    const updateReviewCount = () => {
      document.querySelectorAll('.jdgm-prev-badge__text').forEach(text => {
        const number = parseInt(text.innerText.split(' ')[0]);
        if (!isNaN(number)) {
          text.innerText = `(${number})`;
        }
      });
    };

    const intervalDuration = 500;
    const maxChecks = 20;
    let checkCount = 0;

    const intervalId = setInterval(() => {
      checkCount++;
      // Run the DOM work during idle time so it doesn't add to Total Blocking Time on load.
      idle(updateReviewCount);

      if (checkCount >= maxChecks) {
        clearInterval(intervalId);
      }
    }, intervalDuration);

});
</script>
    {% endif %}

  </body>
</html>
 