<style>
  .promos-mega-menu {
    --overlayTextColor: {{ block.promo_color_text }};
    --columnCount: {{ block.menu_columns }};
    {% if block.enable_overlay %}
      {% if block.overlay_style == 'gradient' %}
        --imageOverlay: {{ block.overlay_gradient }};
      {% else %}
        --imageOverlay: rgba({{ block.overlay_solid.rgba }});
      {% endif %}
    {% endif %}
  }
</style>

<div class="mega-menu-wrapper promos-mega-menu">
  <div class="mega-menu-container">
    <div class="mega-menu-contain">
      {% if link.links.size > 0 %}
        {%- comment -%}
          Use a safe cap on columns (1..8). If merchant set more than 8, we'll cap to 8.
        {%- endcomment -%}
        {% assign requested_columns = block.menu_columns | default: 5 %}
        {% if requested_columns < 1 %}
          {% assign requested_columns = 1 %}
        {% endif %}
        {% if requested_columns > 8 %}
          {% assign requested_columns = 8 %}
        {% endif %}
        {% assign total_columns = requested_columns %}

        {%- comment -%}
          Initialize container HTML vars and counters
        {%- endcomment -%}
        {% assign container1 = '' %}
        {% assign container2 = '' %}
        {% assign container3 = '' %}
        {% assign container4 = '' %}
        {% assign container5 = '' %}
        {% assign container6 = '' %}
        {% assign container7 = '' %}
        {% assign container8 = '' %}

        {% assign count1 = 0 %}
        {% assign count2 = 0 %}
        {% assign count3 = 0 %}
        {% assign count4 = 0 %}
        {% assign count5 = 0 %}
        {% assign count6 = 0 %}
        {% assign count7 = 0 %}
        {% assign count8 = 0 %}

        {% for innerLink in link.links %}
          {%- assign weight = 1 -%}
          {% if innerLink.links.size > 0 %}
            {% assign weight = weight | plus: innerLink.links.size %}
            {% for nestedinnerLink in innerLink.links %}
              {% if nestedinnerLink.links.size > 0 %}
                {% assign weight = weight | plus: nestedinnerLink.links.size %}
              {% endif %}
            {% endfor %}
          {% endif %}

          {% capture item_html %}
            <div class="mega-menu-item-wrapper">
              <a href="{{ innerLink.url }}" class="mega-menu-link mega-menu-link-main {{ settings.header_second_level_menus_size }} {{ settings.header_second_level_menus_font }}-font">
                {{ innerLink.title }}
              </a>
              {% if innerLink.links.size > 0 %}
                <ul class="mega-menu-item-inner">
                  {% for nestedinnerLink in innerLink.links %}
                    <li>
                      <a href="{{ nestedinnerLink.url }}" class="mega-menu-link link-animation {{ settings.header_third_level_menus_size }} {{ settings.header_third_level_menus_font }}-font">
                        {{ nestedinnerLink.title }}
                      </a>
                      {% if nestedinnerLink.links.size > 0 %}
                        <ul>
                          {% for deepLink in nestedinnerLink.links %}
                            <li>
                              <a href="{{ deepLink.url }}" class="mega-menu-link link-animation {{ settings.header_third_level_menus_size }} {{ settings.header_third_level_menus_font }}-font">
                                {{ deepLink.title }}
                              </a>
                            </li>
                          {% endfor %}
                        </ul>
                      {% endif %}
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>
          {% endcapture %}

          {%- comment -%}
            Find the column with smallest count (manual compare)
          {%- endcomment -%}
          {% assign target = 1 %}
          {% assign min_count = count1 %}

          {% if total_columns >= 2 and count2 < min_count %}
            {% assign min_count = count2 %}
            {% assign target = 2 %}
          {% endif %}
          {% if total_columns >= 3 and count3 < min_count %}
            {% assign min_count = count3 %}
            {% assign target = 3 %}
          {% endif %}
          {% if total_columns >= 4 and count4 < min_count %}
            {% assign min_count = count4 %}
            {% assign target = 4 %}
          {% endif %}
          {% if total_columns >= 5 and count5 < min_count %}
            {% assign min_count = count5 %}
            {% assign target = 5 %}
          {% endif %}
          {% if total_columns >= 6 and count6 < min_count %}
            {% assign min_count = count6 %}
            {% assign target = 6 %}
          {% endif %}
          {% if total_columns >= 7 and count7 < min_count %}
            {% assign min_count = count7 %}
            {% assign target = 7 %}
          {% endif %}
          {% if total_columns >= 8 and count8 < min_count %}
            {% assign min_count = count8 %}
            {% assign target = 8 %}
          {% endif %}

          {%- comment -%}
            Append HTML to chosen container and increase its counter by weight
          {%- endcomment -%}
          {% case target %}
            {% when 1 %}
              {% assign container1 = container1 | append: item_html %}
              {% assign count1 = count1 | plus: weight %}
            {% when 2 %}
              {% assign container2 = container2 | append: item_html %}
              {% assign count2 = count2 | plus: weight %}
            {% when 3 %}
              {% assign container3 = container3 | append: item_html %}
              {% assign count3 = count3 | plus: weight %}
            {% when 4 %}
              {% assign container4 = container4 | append: item_html %}
              {% assign count4 = count4 | plus: weight %}
            {% when 5 %}
              {% assign container5 = container5 | append: item_html %}
              {% assign count5 = count5 | plus: weight %}
            {% when 6 %}
              {% assign container6 = container6 | append: item_html %}
              {% assign count6 = count6 | plus: weight %}
            {% when 7 %}
              {% assign container7 = container7 | append: item_html %}
              {% assign count7 = count7 | plus: weight %}
            {% when 8 %}
              {% assign container8 = container8 | append: item_html %}
              {% assign count8 = count8 | plus: weight %}
          {% endcase %}
        {% endfor %}

        {%- comment -%}
          Render only the number of columns needed (1..total_columns)
        {%- endcomment -%}
        <div class="mega-menu-items columns-{{ total_columns }}">
          {% if total_columns >= 1 and container1 != '' %}
            <div class="mega-menu-item">{{ container1 }}</div>
          {% endif %}
          {% if total_columns >= 2 and container2 != '' %}
            <div class="mega-menu-item">{{ container2 }}</div>
          {% endif %}
          {% if total_columns >= 3 and container3 != '' %}
            <div class="mega-menu-item">{{ container3 }}</div>
          {% endif %}
          {% if total_columns >= 4 and container4 != '' %}
            <div class="mega-menu-item">{{ container4 }}</div>
          {% endif %}
          {% if total_columns >= 5 and container5 != '' %}
            <div class="mega-menu-item">{{ container5 }}</div>
          {% endif %}
          {% if total_columns >= 6 and container6 != '' %}
            <div class="mega-menu-item">{{ container6 }}</div>
          {% endif %}
          {% if total_columns >= 7 and container7 != '' %}
            <div class="mega-menu-item">{{ container7 }}</div>
          {% endif %}
          {% if total_columns >= 8 and container8 != '' %}
            <div class="mega-menu-item">{{ container8 }}</div>
          {% endif %}
        </div>
      {% endif %}

      {% if menu_type != 'mega-menu' %}
        {% if block.promo_image_1 != blank or block.promo_image_2 != blank %}
          <div class="mega-menu-promo">
            {% if block.promo_image_1 != blank %}
              {% if block.promo_link_1 != blank %}
                <a href="{{ block.promo_link_1 }}" class="header-promotion-banner-item">
              {% else %}
                <div class="header-promotion-banner-item">
              {% endif %}
              <div class="header-promotion-banner-media">
                <div class="media-card media-adapt media-card-overlay" style="--imageRatio:1;">
                  {% liquid
                    assign image_alt = block.promo_image_1.alt | default: 'Mega menu' | escape
                    assign image_sizes = '(max-width: 600px) 100vw, 540px'
                    assign image_widths = '180, 360, 540'
                  %}
                  {{
                    block.promo_image_1
                    | image_url: width: 540, format: 'webp'
                    | image_tag:
                      sizes: image_sizes,
                      widths: image_widths,
                      decoding: 'async',
                      loading: 'lazy',
                      fetchpriority: 'auto',
                      alt: image_alt
                  }}
                </div>
              </div>
              {%- if block.promo_heading_1 != blank or block.promo_description_1 != blank -%}
                <div class="header-promotion-banner-content-wrapper">
                  {%- if block.promo_heading_1 != blank -%}
                    <h6 class="header-promotion-banner-heading overlay-text {{ block.promo_heading_1_heading_size }}">
                      {{ block.promo_heading_1 }}
                    </h6>
                  {%- endif -%}
                  {%- if block.promo_description_1 != blank -%}
                    <p class="header-promotion-banner-desc overlay-text {{ block.promo_heading_1_description_size }}">
                      {{ block.promo_description_1 }}
                    </p>
                  {%- endif -%}
                </div>
              {%- endif -%}
              {% if block.promo_link_1 != blank %}
                </a>
              {% else %}
                </div>
              {% endif %}
            {% endif %}
            {% if block.promo_image_2 != blank %}
              {% liquid
                assign tag_2 = 'div'
                if block.promo_link_2 != blank
                  assign tag_2 = 'a'
                endif
              %}
              <{{ tag_2 }}
                {% if tag_2 == 'a' %}
                  href="{{ block.promo_link_2 }}"
                {% endif %}
                class="header-promotion-banner-item"
              >
                <div class="header-promotion-banner-media">
                  <div class="media-card media-adapt media-card-overlay" style="--imageRatio:1;">
                    {% liquid
                      assign image_default_alt = 'Mega menu promotion image' | escape
                      assign mega_menu_image_alt = block.promo_image_2.alt | default: image_default_alt
                      assign image_sizes = '(max-width: 767px) 100vw, (max-width: 1024px) 100vw, 100vw'
                      assign image_widths = '180,360,540,720,900,1080, 1200, 1440'
                    %}
                    {{
                      block.promo_image_2
                      | image_url: width: 1440, format: 'webp'
                      | image_tag:
                        sizes: image_sizes,
                        widths: image_widths,
                        decoding: 'async',
                        loading: 'lazy',
                        fetchpriority: 'auto',
                        class: 'hamburger-promotion-media-image',
                        alt: mega_menu_image_alt
                    }}
                  </div>
                </div>
                {%- if block.promo_heading_2 != blank or block.promo_description_2 != blank -%}
                  <div class="header-promotion-banner-content-wrapper">
                    {%- if block.promo_heading_2 != blank -%}
                      <h6 class="header-promotion-banner-heading overlay-text {{ block.promo_heading_2_heading_size }}">
                        {{ block.promo_heading_2 }}
                      </h6>
                    {%- endif -%}
                    {%- if block.promo_description_2 != blank -%}
                      <p class="header-promotion-banner-desc overlay-text {{ block.promo_heading_2_description_size }}">
                        {{ block.promo_description_2 }}
                      </p>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </{{ tag_2 }}>
            {% endif %}
          </div>
        {% endif %}
      {% endif %}
    </div>
  </div>
</div>
