es. We do not offer custom gift wrapping and notes for the time being. We are looking to add them soon. <\/p>"}}},"block_order":["faq_HjaPGC","faq_b3fJ8P","faq_yzbKDn","faq_4ELBta"],"name":"FAQ Accordion (Custom)","settings":{"heading":"Frequently Asked Questions","max_width":1000,"padding_top":60,"padding_bottom":60,"section_bg":"#ffffff","accordion_bg":"#444444","accordion_text":"#ffffff","answer_text":"#333333","heading_size":40,"question_size":16,"answer_size":16,"border_radius":6}},"trust_icons_biVxn6":{"type":"trust-icons","blocks":{"column_AGEMpw":{"type":"column","settings":{"choose_from":"list","icon":"shipping","heading":"Free Shipping on orders $85","description":"Enjoy reliable and efficient delivery to any destination."}},"column_GfXWQt":{"type":"column","settings":{"choose_from":"list","icon":"delivery-box","heading":"Free Breakage Warranty","description":"Enjoy free replacements for damaged & defective products within 10 days of delivery."}},"column_PFqcFN":{"type":"column","settings":{"choose_from":"list","icon":"warranty","heading":"Quality Assurance","description":"Make purchases confidently with safe, encrypted transactions."}},"column_6JnHRm":{"type":"column","settings":{"choose_from":"list","icon":"support","heading":"Lightning Fast Customer Support","description":"Our team is ready to assist you anytime email customerservice@drnkart.com"}}},"block_order":["column_AGEMpw","column_GfXWQt","column_PFqcFN","column_6JnHRm"],"name":"t:sections.trust-icons.presets.name","settings":{"section_visibility":"always","color_scheme":"scheme-6","color_type":"solid","container_width":"container-narrow","select_type":"desktop","top_space_desktop":20,"bottom_space_desktop":20,"top_space_mobile":20,"bottom_space_mobile":20,"columns_desktop":4,"divider_layout":"vertical","heading_size":"text","description_size":"text-small","text_alignment":"left","columns_mobile":"1","swipe_on_mobile":true,"icon_position":"left","icon_size":"small"}},"testimonials_cards_k3q3rr":{