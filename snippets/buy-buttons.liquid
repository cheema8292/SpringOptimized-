<div class="hg__main-mobile">
          {% render 'product-key-highlight',
          section: section,
          blocks: section.blocks,
          product_form_id: product_form_id,
          source: 'main-product'
        %}
        </div>
<div class="product-form__error-message-wrapper" role="alert" hidden>
  <div
    class="product-form__error-message form-message{% if source == 'product-card'%} no-bg{% endif %} form-message-error text-small"
  ></div>
</div>
{% if source != 'product-card' and source != 'cart-drawer' %}
  </div>
{% endif %}
