{% comment %}
  Section: Team Avatars Grid
  - Heading + grid of member blocks
  - Fully configurable via section settings + blocks
{% endcomment %}

<section id="section-{{ section.id }}" class="team-avatars">
  <div class="team-avatars__container">
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <header class="team-avatars__header">
        {% if section.settings.heading != blank %}
          <h2 class="team-avatars__heading">{{ section.settings.heading | escape }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <div class="team-avatars__subheading rte">
            {{ section.settings.subheading }}
          </div>
        {% endif %}
      </header>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="team-avatars__grid" role="list">
        {% for block in section.blocks %}
          {% liquid
            assign img = block.settings.photo
            assign name = block.settings.name
            assign role = block.settings.role
            assign link = block.settings.link
          %}

          <div class="team-avatars__item" role="listitem" {{ block.shopify_attributes }}>
            {% if link != blank %}
              <a class="team-avatars__card" href="{{ link }}">
            {% else %}
              <div class="team-avatars__card">
            {% endif %}

              <div class="team-avatars__avatar-wrap" aria-hidden="true">
                {% if img != blank %}
                  {{ img
                    | image_url: width: 600
                    | image_tag:
                      class: 'team-avatars__avatar',
                      loading: 'lazy',
                      decoding: 'async',
                      fetchpriority: 'low',
                      sizes: '(max-width: 749px) 25vw, (max-width: 990px) 12vw, 96px',
                      widths: '80, 120, 160, 240, 320, 480, 600',
                      alt: img.alt | escape
                  }}
                {% else %}
                  <div class="team-avatars__avatar team-avatars__avatar--placeholder">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="team-avatars__meta">
                {% if name != blank %}
                  <div class="team-avatars__name">{{ name | escape }}</div>
                {% endif %}
                {% if role != blank %}
                  <div class="team-avatars__role">{{ role | escape }}</div>
                {% endif %}
              </div>

            {% if link != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <style>
    /* Scoped variables */
    #section-{{ section.id }}.team-avatars {
      --ta-bg: {{ section.settings.bg_color }};
      --ta-text: {{ section.settings.text_color }};
      --ta-muted: {{ section.settings.muted_color }};
      --ta-maxw-desktop: {{ section.settings.max_width_desktop }}px;
      --ta-maxw-mobile: {{ section.settings.max_width_mobile }}px;

      --ta-pad-top: {{ section.settings.padding_top }}px;
      --ta-pad-bottom: {{ section.settings.padding_bottom }}px;

      --ta-gap-x: {{ section.settings.gap_x }}px;
      --ta-gap-y: {{ section.settings.gap_y }}px;

      --ta-cols-desktop: {{ section.settings.columns_desktop }};
      --ta-cols-mobile: {{ section.settings.columns_mobile }};

      --ta-avatar: {{ section.settings.avatar_size }}px;
      --ta-avatar-mobile: {{ section.settings.avatar_size_mobile }}px;
      --ta-avatar-radius: {{ section.settings.avatar_radius }}%;
      --ta-avatar-border: {{ section.settings.avatar_border_width }}px;
      --ta-avatar-border-color: {{ section.settings.avatar_border_color }};

      --ta-name-size: {{ section.settings.name_size }}px;
      --ta-role-size: {{ section.settings.role_size }}px;

      background: var(--ta-bg);
      color: var(--ta-text);
      padding-top: var(--ta-pad-top);
      padding-bottom: var(--ta-pad-bottom);
    }

    #section-{{ section.id }} .team-avatars__container {
      margin: 0 auto;
      width: 100%;
      max-width: var(--ta-maxw-desktop);
      padding-left: 20px;
      padding-right: 20px;
      text-align: {{ section.settings.text_align }};
    }

    @media (max-width: 749px) {
      #section-{{ section.id }} .team-avatars__container {
        max-width: var(--ta-maxw-mobile);
        padding-left: 16px;
        padding-right: 16px;
      }
    }

    #section-{{ section.id }} .team-avatars__header {
      margin-bottom: {{ section.settings.header_spacing }}px;
    }

    #section-{{ section.id }} .team-avatars__heading {
      margin: 0;
      line-height: 1.1;
      font-size: {{ section.settings.heading_size }}px;
      font-weight: {{ section.settings.heading_weight }};
      letter-spacing: {{ section.settings.heading_letter_spacing }}em;
    }

    @media (max-width: 749px) {
      #section-{{ section.id }} .team-avatars__heading {
        font-size: {{ section.settings.heading_size_mobile }}px;
      }
    }

    #section-{{ section.id }} .team-avatars__subheading {
      margin-top: 10px;
      color: var(--ta-muted);
      font-size: {{ section.settings.subheading_size }}px;
      line-height: 1.5;
    }

    #section-{{ section.id }} .team-avatars__grid {
      display: grid;
      grid-template-columns: repeat(var(--ta-cols-desktop), minmax(0, 1fr));
      gap: var(--ta-gap-y) var(--ta-gap-x);
      align-items: start;
      justify-items: center;
    }

    @media (max-width: 749px) {
      #section-{{ section.id }} .team-avatars__grid {
        grid-template-columns: repeat(var(--ta-cols-mobile), minmax(0, 1fr));
      }
    }

    #section-{{ section.id }} .team-avatars__item {
      width: 100%;
      max-width: 220px; /* keeps items tidy on wide columns */
    }

    #section-{{ section.id }} .team-avatars__card {
      display: grid;
      justify-items: center;
      text-decoration: none;
      color: inherit;
      padding: {{ section.settings.card_padding }}px;
      border-radius: {{ section.settings.card_radius }}px;
      transition: transform .15s ease, background .15s ease;
      background: {{ section.settings.card_bg }};
    }

    #section-{{ section.id }} .team-avatars__card:hover {
      {% if section.settings.enable_hover %}
        transform: translateY(-2px);
        background: {{ section.settings.card_bg_hover }};
      {% endif %}
    }

    #section-{{ section.id }} .team-avatars__avatar-wrap {
      width: 100%;
      border-radius: var(--ta-avatar-radius);
      overflow: hidden;
      border: var(--ta-avatar-border) solid var(--ta-avatar-border-color);
      background: rgba(0,0,0,0.04);
    }

    @media (max-width: 749px) {
      #section-{{ section.id }} .team-avatars__avatar-wrap {
        width: 100%;
        height: auto;
      }
    }

    #section-{{ section.id }} .team-avatars__avatar {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    #section-{{ section.id }} .team-avatars__avatar--placeholder svg {
      width: 100%;
      height: 100%;
    }

    #section-{{ section.id }} .team-avatars__meta {
      margin-top: {{ section.settings.meta_spacing }}px;
      text-align: center;
    }

    #section-{{ section.id }} .team-avatars__name {
      font-size: var(--ta-name-size);
      font-weight: {{ section.settings.name_weight }};
      line-height: 1.2;
    }

    #section-{{ section.id }} .team-avatars__role {
      margin-top: 4px;
      font-size: var(--ta-role-size);
      color: var(--ta-muted);
      line-height: 1.3;
    }
  </style>
</section>

{% schema %}
{
  "name": "Team avatars grid",
  "tag": "section",
  "class": "section team-avatars-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "An incredible team of talented chefs and foodies"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading (optional)",
      "default": "<p></p>"
    },

    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "range",
      "id": "max_width_desktop",
      "label": "Max width (desktop, px)",
      "min": 720,
      "max": 1600,
      "step": 20,
      "default": 1200
    },
    {
      "type": "range",
      "id": "max_width_mobile",
      "label": "Max width (mobile, px)",
      "min": 320,
      "max": 900,
      "step": 10,
      "default": 480
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 7
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "gap_x",
      "label": "Grid gap horizontal (px)",
      "min": 6,
      "max": 40,
      "step": 2,
      "default": 18
    },
    {
      "type": "range",
      "id": "gap_y",
      "label": "Grid gap vertical (px)",
      "min": 6,
      "max": 40,
      "step": 2,
      "default": 18
    },

    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 36
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "Space below header (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 18
    },
    {
      "type": "range",
      "id": "meta_spacing",
      "label": "Space below avatar to text (px)",
      "min": 6,
      "max": 26,
      "step": 1,
      "default": 10
    },

    {
      "type": "header",
      "content": "Avatar"
    },
    {
      "type": "range",
      "id": "avatar_size",
      "label": "Avatar size (desktop, px)",
      "min": 48,
      "max": 140,
      "step": 2,
      "default": 70
    },
    {
      "type": "range",
      "id": "avatar_size_mobile",
      "label": "Avatar size (mobile, px)",
      "min": 40,
      "max": 120,
      "step": 2,
      "default": 62
    },
    {
      "type": "range",
      "id": "avatar_radius",
      "label": "Avatar roundness (%)",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 50
    },
    {
      "type": "range",
      "id": "avatar_border_width",
      "label": "Avatar border width (px)",
      "min": 0,
      "max": 6,
      "step": 1,
      "default": 0
    },
    {
      "type": "color",
      "id": "avatar_border_color",
      "label": "Avatar border color",
      "default": "#e6e6e6"
    },

    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size (desktop, px)",
      "min": 18,
      "max": 60,
      "step": 1,
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size (mobile, px)",
      "min": 18,
      "max": 44,
      "step": 1,
      "default": 28
    },
    {
      "type": "range",
      "id": "heading_weight",
      "label": "Heading weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "default": 700
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size (px)",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "name_size",
      "label": "Name size (px)",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 13
    },
    {
      "type": "range",
      "id": "role_size",
      "label": "Role size (px)",
      "min": 10,
      "max": 18,
      "step": 1,
      "default": 11
    },
    {
      "type": "range",
      "id": "name_weight",
      "label": "Name weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "default": 600
    },

    {
      "type": "header",
      "content": "Card (optional)"
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding (px)",
      "min": 0,
      "max": 24,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius (px)",
      "min": 0,
      "max": 24,
      "step": 1,
      "default": 12
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "color",
      "id": "card_bg_hover",
      "label": "Card hover background",
      "default": "rgba(0,0,0,0.04)"
    },
    {
      "type": "checkbox",
      "id": "enable_hover",
      "label": "Enable hover lift effect",
      "default": true
    },

    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text color",
      "default": "#6b6b6b"
    }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Member",
      "settings": [
        { "type": "image_picker", "id": "photo", "label": "Photo" },
        { "type": "text", "id": "name", "label": "Name", "default": "Name Surname" },
        { "type": "text", "id": "role", "label": "Role / title", "default": "Chef" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "max_blocks": 24,
  "presets": [
    {
      "name": "Team avatars grid",
      "blocks": [
        { "type": "member", "settings": { "name": "Him Chowun", "role": "Chef Instructor" } },
        { "type": "member", "settings": { "name": "Izabela Tabakova", "role": "Chef Instructor" } },
        { "type": "member", "settings": { "name": "Fatima Delgado", "role": "Chef Instructor" } },
        { "type": "member", "settings": { "name": "Harrison Phillips", "role": "Chef Instructor" } },
        { "type": "member", "settings": { "name": "Pablo Carreño", "role": "Chef Instructor" } },
        { "type": "member", "settings": { "name": "Corabelle Durand", "role": "Chef Instructor" } }
      ]
    }
  ]
}
{% endschema %}
