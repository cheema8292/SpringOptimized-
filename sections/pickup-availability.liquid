{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{%- liquid 
  assign pick_up_availabilities = product_variant.store_availabilities | where: 'pick_up_enabled', true 
-%}

{%- if pick_up_availabilities.size > 0 -%}
  <pickup-availability-preview class="pickup-availability-preview">
    {% assign closest_location = pick_up_availabilities.first %}

    {% if closest_location.available %}
      {% render 'svg-icons', icon_type: 'pickup-icon' %}
    {% endif %}

    <div class="pickup-availability-info">
      {%- if closest_location.available -%}
        <div class="product-pickup-availability-info-inner">
          <p class="pickup-availability-info-location text-small">
            {{
              'products.product.pickup_availability.pick_up_available_at_html'
              | t: location_name: closest_location.location.name
            }}
          </p>
          <p class="pickup-availability-info-pickup-time text-small">{{ closest_location.pick_up_time }}</p>
        </div>
        <button
          id="ShowPickupAvailabilityDrawer-{{ product_variant.id }}"
          data-variant-id="{{ product_variant.id }}"
          class="pickup-availability-button text-xsmall text-underline"
          aria-haspopup="dialog"
          aria-label="Show pickup availability"
        >
          {%- if pick_up_availabilities.size == 1 -%}
            {{ 'products.product.pickup_availability.view_store_info' | t }}
          {%- else -%}
            {{ 'products.product.pickup_availability.check_other_stores' | t }}
          {%- endif -%}
        </button>
      {%- else -%}
        <div class="product-pickup-availability-info-inner">
          <p class="pickup-availability-info-location text-small">
            {{
              'products.product.pickup_availability.pick_up_unavailable_at_html'
              | t: location_name: closest_location.location.name
            }}
          </p>
        </div>
        {%- if pick_up_availabilities.size > 1 -%}
          <button
            id="ShowPickupAvailabilityDrawer-{{ product_variant.id }}"
            data-variant-id="{{ product_variant.id }}"
            class="pickup-availability-button text-xsmall text-underline"
            aria-haspopup="dialog"
            aria-label="Show pickup availability"

          >
            {{ 'products.product.pickup_availability.check_other_stores' | t }}
          </button>
        {%- endif -%}
      {%- endif -%}
    </div>
  </pickup-availability-preview>
  <pickup-availability-drawer
    class="drawer drawer-right drawer-small drawer-fixed {{ settings.drawer_popup_color_scheme }}"
    id="pickup-availability-drawer-{{ product_variant.id }}"
    tabindex="-1"
    role="dialog"
    aria-modal="true"
    aria-labelledby="PickupAvailabilityHeading-{{ product_variant.id }}"
  >
    <div class="drawer-backdrop" drawer-close></div>
    <div class="drawer-inner">
      <div class="drawer-contentwrap color-scheme">
        <div class="drawer-content">
          <div class="drawer-head">
            <div class="drawer-head-inner border-bottom">
             <div class="drawer-heading heading-font h5 heading-color">{{ 'products.product.pickup_availability.title' | t }}</div>
              <button class="drawer-close-btn" type="button" aria-label="{{ 'accessibility.close' | t }}">
                {% render 'svg-icons', icon_type: 'cross-icon' %}
              </button>
            </div>
          </div>
          <div class="drawer-body">
            <div class="pickup-availability-body">
              <div class="pickup-availability-header">
                <h6 class="pickup-availability-drawer-title text" id="PickupAvailabilityHeading-{{ product_variant.id }}"> {{ product_variant.product.title | escape }}</h6>
                {%- unless product_variant.product.has_only_default_variant -%}
                  <p class="pickup-availability-variant text-small" data-title="{{ product_variant.title }}">
                    {%- for product_option in product_variant.product.options_with_values -%}
                      {{ product_option.name | escape }}:&nbsp;
                      {%- for value in product_option.values -%}
                        {%- if product_option.selected_value == value -%}
                          <span>{{ value | escape }}</span>
                        {%- endif -%}
                      {%- endfor -%}
                      {%- unless forloop.last -%},&nbsp;{%- endunless -%}
                    {%- endfor -%}
                  </p>
                {%- endunless -%}
              </div>

              <ul class="pickup-availability-list" role="list" data-store-availability-drawer-content>
                {%- for availability in pick_up_availabilities -%}
                  <li class="pickup-availability-list-item">
                    <h3 class="text">{{ availability.location.name | escape }}</h3>
                    <p class="pickup-availability-preview text-small">
                      {%- if availability.available -%}
                        {% render 'svg-icons', icon_type: 'pickup-icon' %}
                        {{ 'products.product.pickup_availability.pick_up_available' | t }},
                        {{ availability.pick_up_time | downcase }}
                      {%- endif -%}
                    </p> 

                    {%- assign address = availability.location.address -%}
                    <address class="pickup-availability-address text-small font-style-normal">
                      {{ address | format_address }}

                      {%- if address.phone.size > 0 -%}
                        <p>{{ address.phone }}</p>
                      {%- endif -%}
                    </address>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </pickup-availability-drawer>
{%- endif -%}
