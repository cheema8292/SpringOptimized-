{% comment %} {{ 'collection-list.css' | asset_url | stylesheet_tag }} performance changes {% endcomment %}

<div class="color-scheme {{ section.settings.color_scheme }} section-spacing color-{{ section.settings.color_type }}">
  <div class="{{ section.settings.container_width }}">
    {% assign text_alignment = 'text-' | append: section.settings.heading_content_alignment %}
    {% liquid
      if section.settings.layout_type == 'carousel'
        assign text_alignment = 'text-left'
      endif
    %}
    {% assign description_data = '' %}
    {% if section.settings.description != blank %}
      {% assign description_data = '<p class="'
        | append: section.settings.description_size
        | append: '">'
        | append: section.settings.description
        | newline_to_br
        | append: '</p>'
      %}
    {% endif %}
    {% liquid
      assign is_slider = false
      assign grid_count = 4
      if section.blocks.size > section.settings.desktop_column_count or section.blocks.size > grid_count
        assign is_slider = true
      endif
    %}

    {% if section.settings.layout_type == 'carousel' and is_slider %}
      <div class="section-header-with-nav">
    {% endif %}

    {% render 'section-heading',
      section_heading_tag: section.settings.heading_tag,
      section_heading_size: section.settings.heading_size,
      section_heading_content: section.settings.heading,
      section_heading_highlight_text: section.settings.highlight_text,
      section_heading_highlight_font: section.settings.highlight_font,
      section_extra_classes: text_alignment,
      extra_html_content: description_data
    %}
    {% if section.settings.layout_type == 'carousel' and is_slider %}
      {% render 'swiper-navigation', id: section.id, extra_class: 'md-flex d-none' %}
    {% endif %}
    {% if section.settings.layout_type == 'carousel' and is_slider %}
      </div>
    {% endif %}
    {% if section.blocks.size > 0 %}      
      <collection-list-carousel
        class="collection-list-wrapper {% if section.settings.layout_type == "carousel" and is_slider %} swiper {% endif %}"
        id="colleciton-list-outer-{{ section.id }}"
        data-section="{{ section.id }}"
        {% if section.settings.layout_type == 'carousel' and is_slider %}
          data-swiper='
            {
  
              "loop": false,
              "autoHeight": false,
              "speed":1000,
              "slidesPerView": 1.3,
              "spaceBetween": {{ section.settings.column_gap }},
              "navigation": {
                      "nextEl": ".swiper-nav-next-{{ section.id }}",
                      "prevEl": ".swiper-nav-prev-{{ section.id  }}"
                    },
              "breakpoints": {
                  "768": {
                    "slidesPerView": {% if section.settings.desktop_column_count  <= 2 %}{{ section.settings.desktop_column_count }}{% else %}3{% endif %}
                  },
                  "1025": {
                        "slidesPerView": {% if section.settings.desktop_column_count  <= 3 %}{{ section.settings.desktop_column_count }}{% else %}4{% endif %}
                  },
                  "1280": {
                    "slidesPerView": {{ section.settings.desktop_column_count }}
                  }
                },
              "centeredSlides": false
            }
          '
        {% endif %}
      >
        <div class="{%  if section.settings.title_position == "on_image" %}overlay-content  {% endif %} {% if section.settings.enable_mobile_swipe %}mobile-swipe{% endif %} {%  if section.settings.layout_type == "carousel" and is_slider %}swiper-wrapper {% else %}collection-list-grid{% endif %} mobile-stacked mobile-column-{{ section.settings.columns_mobile }}">
          {% liquid
            assign image_size = section.settings.aspect_ratio
            assign extra_class = ''
            if section.settings.layout_type == 'carousel' and is_slider
              assign extra_class = 'swiper-slide'
            endif
            if section.blocks.size > 0
              for block in section.blocks
                capture current
                  cycle section.id: 1, 2, 3, 4
                endcapture
                assign placeholder_image = 'collection-apparel-' | append: current
                if block.settings.collection != blank
                  render 'collection-card', collection: block.settings.collection, section: section, image_size: image_size, placeholder_image: placeholder_image, block: block, extra_class: extra_class
                else
                  render 'collection-card', collection: null, section: section, image_size: image_size, placeholder_image: placeholder_image, extra_class: extra_class
                endif
              endfor
            endif
          %}
        </div>
      </collection-list-carousel>
    {% endif %}
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} {
    --topSpacer: {{ section.settings.top_space_desktop }}px;
    --bottomSpacer:{{ section.settings.bottom_space_desktop }}px;
    --columnGap: {{ section.settings.column_gap  }}px;
    --blockRadius: {{ section.settings.border_radius }}px;
     {% if section.settings.enable_overlay %}
        {% if section.settings.overlay_style == 'gradient' %}
          --imageOverlay: {{ section.settings.overlay_gradient }};
        {% else %}
          --imageOverlay: rgba({{ section.settings.overlay_solid.rgba }});
        {% endif %}
      {% endif %}
    {% if section.settings.desktop_column_count <= 2 %}
      --columnCount: {{ section.settings.desktop_column_count }};
    {% else %} 
      --columnCount: 3;
    {% endif %}
  }
  #shopify-section-{{ section.id }} .text-highlight-color{
    --highlightColor:{{ section.settings.text_color }};
  }
  #shopify-section-{{ section.id }} .text-highlight-gradiant{
    --highlightColor:{{ section.settings.gradiant_color }};
  }
  @media (min-width:1025px) {
    #shopify-section-{{ section.id }}{
      {% if section.settings.desktop_column_count <= 3 %}
        --columnCount: {{ section.settings.desktop_column_count }};
      {% else %}
        --columnCount: 4;
      {% endif %}
    }
  }
  @media (min-width:1280px) {
    #shopify-section-{{ section.id }} {
      --columnCount: {{ section.settings.desktop_column_count }};
    }
  }
  @media only screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      --topSpacer: {{ section.settings.top_space_mobile }}px;
      --bottomSpacer: {{ section.settings.bottom_space_mobile }}px;
      --columnCount: {{ section.settings.columns_mobile }};
      --columnGap: {{ section.settings.mobile_column_gap  }}px;
      {% if section.settings.border_radius > 10 %}
        --blockRadius: calc( {{ section.settings.border_radius }}px / 2);
      {% else %}
        --blockRadius: {{ section.settings.border_radius }}px ;
      {% endif %}
    }
  }
  {% if section.settings.section_visibility == 'large' %}
    @media(max-width: 767px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
</style>

