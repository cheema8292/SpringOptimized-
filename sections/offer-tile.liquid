      "visible_if": "{{ section.settings.overlay_style == 'solid' }}"
    }
  ],
  "presets": [
    {
      "name": "Offer tile",
      "category": "Storytelling",
      "blocks": [
        {
          "type": "subheading"
        },
        {
          "type": "heading"
        },
        {
          "type": "divider"
        },
        {
          "type": "description"
        }
      ]
    }
  ]
}
{% endschema %}
