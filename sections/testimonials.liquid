{% comment %}
  {% stylesheet %}
  {% endstylesheet %}
{% endcomment %}
{{ 'testimonials.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign is_testimonial_slider = false
  if section.blocks.size > 1
    assign is_testimonial_slider = true
  endif
-%}
<div class="color-scheme {{ section.settings.color_scheme }} color-{{ section.settings.color_type }} section-spacing">
  <div class="container-small">
    {% if section.blocks.size > 0 or section.settings.heading != blank %}
      <testimonials-slider class="testimonial-element" data-section="{{ section.id }}">
        {% assign text_alignment = 'text-' | append: section.settings.content_alignment %}
        {% render 'section-heading',
          section_heading_tag: section.settings.heading_tag,
          section_heading_size: section.settings.heading_size,
          section_heading_content: section.settings.heading,
          section_heading_highlight_text: section.settings.highlight_text,
          section_heading_highlight_font: section.settings.highlight_font,
          section_extra_classes: text_alignment,
          extra_html_content: ''
        %}
        {% if section.blocks.size > 0 %}
          <div
            class="testimonials-main-outer{%if is_testimonial_slider %} swiper{% endif %}"
            {% if is_testimonial_slider %}
              data-swiper='
                {
                  "loop": true,
                  "slidesPerView": 1,
                  "spaceBetween": 0,
                  "speed":1000,
                  "watchSlidesProgress": true,
                  "pagination": {
                    "el": ".swiper-pagination-{{ section.id }}",
                    "clickable": true
                  },
                  "autoplay": {
                    "enabled": {{ section.settings.auto_rotate }},
                    "delay": {{ section.settings.change_slides_speed | times: 1000 }},
                    "disableOnInteraction": false,
                    "pauseOnMouseEnter": false
                  }
                }
              '
            {% endif %}
          >
            <div class="testimonials-wrapper{%if is_testimonial_slider %} swiper-wrapper{% endif %}">
              {% for block in section.blocks %}
                {% if block.settings.text != blank %}
                  <div
                    class="testimonial-item{%if is_testimonial_slider %} swiper-slide{% endif %}"
                    {{ block.shopify_attributes }}
                  >
                    <div class="testimonial-item-inner">
                      <div class="testimonial-quote">
                        {% render 'svg-icons', icon_type: 'icon-quote' %}
                      </div>
                      {% if block.settings.text != blank %}
                        <p class="testimonial-review-text {{ section.settings.text_size }}">
                          {{ block.settings.text | replace: '<a', '<a class="text-underline"' }}
                        </p>
                      {% endif %}
                      {%- if block.settings.author != blank or block.settings.author_location != blank -%}
                        <div class="testimonial-info">
                          {%- if block.settings.image != blank -%}
                            <div class="testimonial-thumb-img">
                              <div class="media-card media-adapt" style="--imageRatio:1/1;">
                                {% liquid
                                  assign testimonial_card_default_alt = 'Author image - ' | append: forloop.index
                                  assign testimonial_author_default_alt = block.settings.author
                                  assign testimonial_card_image_alt = block.settings.image.alt | default: testimonial_author_default_alt | default: testimonial_card_default_alt
                                %}
                                {{
                                  block.settings.image
                                  | image_url: width: 1200, format: 'webp'
                                  | image_tag:
                                    sizes: '(max-width: 767px) 100vw',
                                    widths: '324, 416, 991, 1200',
                                    decoding: 'async',
                                    loading: 'lazy',
                                    fetchpriority: 'auto',
                                    alt: testimonial_card_image_alt
                                }}
                              </div>
                            </div>
                          {% endif %}
                          <div class="testimonial-author-info">
                            {% if block.settings.author != blank %}
                              <div class="testimonial-author-name heading-font h6">{{ block.settings.author }}</div>
                            {% endif %}
                            {% if block.settings.author_location != blank %}
                              <span class="testimonial-author-location text-light">
                                {{- block.settings.author_location -}}
                              </span>
                            {% endif %}
                          </div>
                        </div>
                      {% endif %}
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
            <div class="swiper-pagination bullet-left swiper-pagination-{{ section.id }}"></div>
          </div>
        {% endif %}
      </testimonials-slider>
    {% endif %}
  </div>
</div>
<style>
    #shopify-section-{{ section.id }}{
     --topSpacer: {{ section.settings.top_space_desktop }}px;
     --bottomSpacer:{{ section.settings.bottom_space_desktop }}px;
    }
    #shopify-section-{{ section.id }} .text-highlight-color{
      --highlightColor:{{ section.settings.text_color }};
    }
    #shopify-section-{{ section.id }} .text-highlight-gradiant{
      --highlightColor:{{ section.settings.gradiant_color }};
    }
    @media only screen and (max-width: 767px) {
      #shopify-section-{{ section.id }}{
        --topSpacer: {{ section.settings.top_space_mobile }}px;
        --bottomSpacer: {{ section.settings.bottom_space_mobile }}px;
      }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "class": "testimonial-section",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer", "custom.Overlay"] },
  "blocks": [
    {
      "type": "testimonial",
      "name": "t:sections.testimonials.blocks.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "t:sections.testimonials.blocks.settings.review",
          "default": "Add customer reviews and testimonials to showcase your store's happy customers."
        },
        {
          "type": "text",
          "id": "author",
          "label": "t:sections.testimonials.blocks.settings.author_name",
          "default": "Author's name"
        },
        {
          "type": "text",
          "id": "author_location",
          "label": "t:sections.testimonials.blocks.settings.author_location",
          "default": "Location"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.testimonials.blocks.settings.avatar"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.headers.general"
    },
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:sections.all.settings.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:sections.all.settings.section_visibility.always.label",
          "value": "always"
        },
        {
          "label": "t:sections.all.settings.section_visibility.small_devices.label",
          "value": "small"
        },
        {
          "label": "t:sections.all.settings.section_visibility.large_devices.label",
          "value": "large"
        }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "t:sections.all.settings.colors.label"
    },
    {
      "type": "select",
      "id": "color_type",
      "label": "t:sections.all.settings.color_background.label",
      "default": "solid",
      "options": [
        {
          "label": "t:sections.all.settings.color_background.options.background_solid",
          "value": "solid"
        },
        {
          "label": "t:sections.all.settings.color_background.options.background_gradiant",
          "value": "gradient"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.section_spacing"
    },
    {
      "type": "select",
      "id": "select_type",
      "label": "t:sections.all.settings.section_spacing.choose_from.label",
      "options": [
        {
          "label": "t:sections.all.settings.section_spacing.choose_from.options.desktop.label",
          "value": "desktop"
        },
        {
          "label": "t:sections.all.settings.section_spacing.choose_from.options.mobile.label",
          "value": "mobile"
        }
      ],
      "default": "desktop"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:sections.all.settings.section_spacing.top_spacing.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.select_type == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:sections.all.settings.section_spacing.bottom_spacing.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.select_type == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:sections.all.settings.section_spacing.top_spacing.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.select_type == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:sections.all.settings.section_spacing.bottom_spacing.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.select_type == 'mobile' }}"
    },
    {
      "type": "header",
      "content": "t:sections.testimonials.blocks.name"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "t:sections.testimonials.settings.auto_rotate",
      "default": false
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "t:sections.testimonials.settings.change_slides_speed",
      "default": 5
    },
    {
      "type": "select",
      "id": "text_size",
      "label": "t:sections.all.settings.heading_size.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.settings.heading_size.options.heading_xl"
        },
        {
          "value": "h2",
          "label": "t:sections.all.settings.heading_size.options.heading_l"
        },
        {
          "value": "h3",
          "label": "t:sections.all.settings.heading_size.options.heading_m"
        },
        {
          "value": "h4",
          "label": "t:sections.all.settings.heading_size.options.heading_s"
        },
        {
          "value": "h5",
          "label": "t:sections.all.settings.heading_size.options.heading_xs"
        },
        {
          "value": "h6",
          "label": "t:sections.all.settings.heading_size.options.heading_xxs"
        }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.section_header"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.all.headers.heading",
      "default": "Testimonials",
      "info": "t:sections.all.settings.heading_info.info"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.all.settings.heading_tag.label",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        },
        {
          "value": "div",
          "label": "Div"
        },
        {
          "value": "span",
          "label": "Span"
        },
        {
          "value": "p",
          "label": "P"
        }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.all.settings.heading_size.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.settings.heading_size.options.heading_xl"
        },
        {
          "value": "h2",
          "label": "t:sections.all.settings.heading_size.options.heading_l"
        },
        {
          "value": "h3",
          "label": "t:sections.all.settings.heading_size.options.heading_m"
        },
        {
          "value": "h4",
          "label": "t:sections.all.settings.heading_size.options.heading_s"
        },
        {
          "value": "h5",
          "label": "t:sections.all.settings.heading_size.options.heading_xs"
        },
        {
          "value": "h6",
          "label": "t:sections.all.settings.heading_size.options.heading_xxs"
        }
      ],
      "default": "h2"
    },
    {
      "type": "text_alignment",
      "id": "content_alignment",
      "label": "t:sections.all.settings.content_alignment.label",
      "default": "left"
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.highlight_content"
    },
    {
      "type": "select",
      "id": "highlight_text",
      "label": "t:sections.all.settings.highlight_text.label",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.settings.highlight_text.options.none"
        },
        {
          "value": "underline",
          "label": "t:sections.all.settings.highlight_text.options.underline"
        },
        {
          "value": "color",
          "label": "t:sections.all.settings.highlight_text.options.markertextcolor"
        },
        {
          "value": "gradiant",
          "label": "t:sections.all.settings.highlight_text.options.markergradiant"
        }
      ],
      "default": "color"
    },
    {
      "type": "select",
      "id": "highlight_font",
      "label": "t:sections.all.settings.fontStyle.label",
      "options": [
        {
          "value": "heading-font",
          "label": "t:sections.all.settings.fontStyle.options.headingFont"
        },
        {
          "value": "body-font",
          "label": "t:sections.all.settings.fontStyle.options.bodyFont"
        },
        {
          "value": "accent-font",
          "label": "t:sections.all.settings.fontStyle.options.accent"
        }
      ],
      "default": "heading-font"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.all.headers.markertextcolor",
      "visible_if": "{{ section.settings.highlight_text == 'color' }}",
      "default": "#0424A7"
    },
    {
      "type": "color_background",
      "id": "gradiant_color",
      "label": "t:sections.all.headers.markertextcolor",
      "default": "linear-gradient(54deg, rgba(239, 37, 18, 1) 4%, rgba(239, 95, 18, 1) 52.518%, rgba(241, 163, 28, 1) 100%)",
      "visible_if": "{{ section.settings.highlight_text == 'gradiant' }}"
    }
  ],
  "presets": [
    {
      "name": "t:sections.testimonials.presets.name",
      "category": "Storytelling",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
