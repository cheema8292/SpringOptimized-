{% doc %}
  @prompt
    us vs them comparison section with image, flip our brand to show on the left side 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-comparison-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-comparison-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-comparison-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-comparison-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px;
  }

  .ai-comparison-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-comparison-content-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }

  .ai-comparison-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-comparison-column-{{ ai_gen_id }}--us {
    order: -1;
  }

  .ai-comparison-column-header-{{ ai_gen_id }} {
    text-align: center;
    padding: 20px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-comparison-column-header-{{ ai_gen_id }}--them {
    background-color: {{ block.settings.them_bg_color }};
  }

  .ai-comparison-column-header-{{ ai_gen_id }}--us {
    background-color: {{ block.settings.us_bg_color }};
  }

  .ai-comparison-column-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.column_title_size }}px;
    margin: 0;
  }

  .ai-comparison-column-title-{{ ai_gen_id }}--them {
    color: {{ block.settings.them_text_color }};
  }

  .ai-comparison-column-title-{{ ai_gen_id }}--us {
    color: {{ block.settings.us_text_color }};
  }

  .ai-comparison-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    margin-bottom: 20px;
  }

  .ai-comparison-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-comparison-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-comparison-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-comparison-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-comparison-items-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-comparison-item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px;
    background-color: {{ block.settings.item_bg_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-comparison-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-comparison-icon-{{ ai_gen_id }}--them {
    color: {{ block.settings.them_icon_color }};
  }

  .ai-comparison-icon-{{ ai_gen_id }}--us {
    color: {{ block.settings.us_icon_color }};
  }

  .ai-comparison-item-text-{{ ai_gen_id }} {
    flex: 1;
    font-size: {{ block.settings.item_text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-comparison-content-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .ai-comparison-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-comparison-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }

    .ai-comparison-column-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.column_title_size }}px * 0.9);
    }
  }
{% endstyle %}

<us-vs-them-comparison-{{ ai_gen_id }}
  class="ai-comparison-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-comparison-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-comparison-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-comparison-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <div class="ai-comparison-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-comparison-content-{{ ai_gen_id }}">
      <div class="ai-comparison-column-{{ ai_gen_id }} ai-comparison-column-{{ ai_gen_id }}--us">
        <div class="ai-comparison-column-header-{{ ai_gen_id }} ai-comparison-column-header-{{ ai_gen_id }}--us">
          <h3 class="ai-comparison-column-title-{{ ai_gen_id }} ai-comparison-column-title-{{ ai_gen_id }}--us">
            {{ block.settings.us_title }}
          </h3>
        </div>

        {% if block.settings.us_image %}
          <div class="ai-comparison-image-wrapper-{{ ai_gen_id }}">
            <img
              src="{{ block.settings.us_image | image_url: width: 800 }}"
              alt="{{ block.settings.us_image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.us_image.width }}"
              height="{{ block.settings.us_image.height }}"
              class="ai-comparison-image-{{ ai_gen_id }}"
            >
          </div>
        {% else %}
          <div class="ai-comparison-image-wrapper-{{ ai_gen_id }}">
            <div class="ai-comparison-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-comparison-empty-state-{{ ai_gen_id }}">
                Add an image for "{{ block.settings.us_title }}"
              </div>
            </div>
          </div>
        {% endif %}

        <div class="ai-comparison-items-{{ ai_gen_id }}">
          {% for i in (1..5) %}
            {% liquid
              assign item_key = 'us_item_' | append: i
              assign item_text = block.settings[item_key]
            %}
            {% if item_text != blank %}
              <div class="ai-comparison-item-{{ ai_gen_id }}">
                <div class="ai-comparison-icon-{{ ai_gen_id }} ai-comparison-icon-{{ ai_gen_id }}--us">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                </div>
                <p class="ai-comparison-item-text-{{ ai_gen_id }}">{{ item_text }}</p>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="ai-comparison-column-{{ ai_gen_id }}">
        <div class="ai-comparison-column-header-{{ ai_gen_id }} ai-comparison-column-header-{{ ai_gen_id }}--them">
          <h3 class="ai-comparison-column-title-{{ ai_gen_id }} ai-comparison-column-title-{{ ai_gen_id }}--them">
            {{ block.settings.them_title }}
          </h3>
        </div>

        {% if block.settings.them_image %}
          <div class="ai-comparison-image-wrapper-{{ ai_gen_id }}">
            <img
              src="{{ block.settings.them_image | image_url: width: 800 }}"
              alt="{{ block.settings.them_image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.them_image.width }}"
              height="{{ block.settings.them_image.height }}"
              class="ai-comparison-image-{{ ai_gen_id }}"
            >
          </div>
        {% else %}
          <div class="ai-comparison-image-wrapper-{{ ai_gen_id }}">
            <div class="ai-comparison-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-comparison-empty-state-{{ ai_gen_id }}">
                Add an image for "{{ block.settings.them_title }}"
              </div>
            </div>
          </div>
        {% endif %}

        <div class="ai-comparison-items-{{ ai_gen_id }}">
          {% for i in (1..5) %}
            {% liquid
              assign item_key = 'them_item_' | append: i
              assign item_text = block.settings[item_key]
            %}
            {% if item_text != blank %}
              <div class="ai-comparison-item-{{ ai_gen_id }}">
                <div class="ai-comparison-icon-{{ ai_gen_id }} ai-comparison-icon-{{ ai_gen_id }}--them">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                  </svg>
                </div>
                <p class="ai-comparison-item-text-{{ ai_gen_id }}">{{ item_text }}</p>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</us-vs-them-comparison-{{ ai_gen_id }}>

<script>
  (function() {
    class UsVsThemComparison{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('us-vs-them-comparison-{{ ai_gen_id }}', UsVsThemComparison{{ ai_gen_id }});
  })();
</script>

