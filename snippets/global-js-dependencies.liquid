try{
  const localStorageRecentView = 'metro-recent-viewed-products';
  const recentViewProducts = JSON.parse(window.localStorage.getItem(localStorageRecentView) || "[]");
  const productIdRecent = `{{ product.id }}`;
  if(productIdRecent != ''){
    const existingIndex = recentViewProducts.indexOf(productIdRecent);
    if (existingIndex !== -1) {
      recentViewProducts.splice(existingIndex, 1);
    }
    recentViewProducts.unshift(productIdRecent);
    if(recentViewProducts.length > 10) {
      recentViewProducts.pop();
    }
    const jsonStringRecentProducts = JSON.stringify(recentViewProducts);
    window.localStorage.setItem(localStorageRecentView, jsonStringRecentProducts);
  }
}catch (error) {
