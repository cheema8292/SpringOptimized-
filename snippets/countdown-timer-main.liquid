{{ 'countdown-timer-main.css' | asset_url | stylesheet_tag }}
{% liquid
  assign desktop_image = section.settings.image_picker
  assign mobile_image = section.settings.mobile_image_picker | default: desktop_image
%}

<div class="countdown-wrapper pos-relative {%  if section.settings.rounded_corners == "all" %}{{ section.settings.rounded_corners_type }}{% endif %}">
  <div class="countdown-media media-card-overlay media-wrapper">
    <div
      class="media-card media-fixed"
      {% if settings.image_animation_type != 'none' %}
        animate-element="true"
        data-animate="{{ settings.image_animation_type }}"
        data-zoom-initial="1.1"
        data-zoom-final="1.0"
        data-zoom-duration="1.5"
        data-zoom-ease="power3.out"
        data-delay="0.3"
      {% endif %}
    >
      {% if section.settings.image_picker != blank or section.settings.mobile_image_picker != blank %}
        {% if desktop_image != blank %}
          {% liquid
            assign desktop_image_default_alt = 'Countdown timer banner image' | escape
            assign desktop_image_alt = desktop_image.alt | default: desktop_image_default_alt
          %}
          {{
            desktop_image
            | image_url: width: 3840, format: 'webp'
            | image_tag:
              sizes: '(max-width: 767px) 100vw, (max-width: 1024px) 100vw, (max-width: 1367px) 100vw, (max-width: 1599px) 100vw, 100vw',
              widths: '375, 550, 750, 900, 1200, 1500, 1800, 2100, 2400, 2700, 3000, 3300, 3600, 3840',
              decoding: 'async',
              loading: loading,
              fetchpriority: 'auto',
              alt: desktop_image_alt,
              class: 'd-none md-block'
          }}

        {% else %}
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
        {% if mobile_image != blank %}
          {% liquid
            assign mobile_image_default_alt = 'Countdown timer banner image' | escape
            assign mobile_image_alt = mobile_image.alt | default: mobile_image_default_alt
          %}
          {{
            mobile_image
            | image_url: width: 1780, format: 'webp'
            | image_tag:
              sizes: '(max-width: 767px) 100vw',
              widths: '320, 480, 640, 750, 828, 1200, 1500, 1780',
              decoding: 'async',
              loading: loading,
              fetchpriority: 'auto',
              alt: mobile_image_alt,
              class: 'd-block md-none'
          }}
        {% else %}
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}

      {% else %}
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>
  </div>
  {% if section.blocks.size > 0 %}
    <div class="countdown-content pos-relative d-flex {{ section.settings.content_position }} {{ section.settings.content_alignment }}">
      <div class="countdown-content-inner rich-text-block">
        {{ slides }}
      </div>
    </div>
  {% endif %}
</div>
