 {% if request.design_mode %} 
 <script src="{{ 'transparent-header.js' | asset_url }}" defer="defer"></script>
 {% endif %}
{% liquid
    assign loading = 'lazy'
  if section.index <= 3
    assign loading = 'eager'
  endif

%} 
 {% capture blocks %}
    {% content_for 'blocks' %}
  {% endcapture %}
<div class="color-scheme {{ section.settings.color_scheme }} color-{{ section.settings.color_type }} section-spacing" {%  if section.settings.header_transparent %}allow-header-transparent {% endif %}>
  <div class="{{ section.settings.container_width }}">

    {%  render 'video',
          rounded_corners: section.settings.rounded_corners,
          rounded_corners_type: section.settings.rounded_corners_type,
          desktop_video: section.settings.desktop_video,
          desktop_video_url: section.settings.desktop_url,
          mobile_video: section.settings.mobile_video,
          mobile_video_url: section.settings.mobile_url,
          content_visibility: section.settings.content_visibility,
          desktop_cover_image: section.settings.desktop_cover_image,
          mobile_cover_image: section.settings.mobile_cover_image,
          button_text: section.settings.play_btn_text,
          desktop_alt_text: section.settings.desktop_alt_text,
          mobile_alt_text: section.settings.mobile_alt_text,
          autoplay: section.settings.autoplay,
          loop: section.settings.loop,
          control: true,
          blocks: blocks,
          content_alignment: section.settings.content_alignment,
          content_position: section.settings.content_position,
          mobile_content_position: section.settings.mobile_content_position,
          mobile_content_alignment: "justify-content-center text-center",
          isHeight: false,
          loading:loading
          %}
  </div>  
  </div>

<style>
    #shopify-section-{{ section.id }}{
     --topSpacer: {{ section.settings.top_space_desktop }}px;
     --bottomSpacer:{{ section.settings.bottom_space_desktop }}px;
     --sectionRadius:{{ section.settings.border_radius }}px;
     --iconColor:{{ section.settings.play_btn_color }};
      {% if section.settings.desktop_media_height == "100vh" %}
        --mediaHeight: {{ section.settings.desktop_media_height }};
      {% else %}
        --mediaHeight: {{ section.settings.desktop_custom_height }}px;
      {% endif %}
      {% if section.settings.enable_overlay %}
       {% if section.settings.overlay_style == 'gradient' %}  
        --imageOverlay: {{ section.settings.overlay_gradient }};
       {% else %}
       --imageOverlay: rgba({{ section.settings.overlay_solid.rgba }});
       {% endif %}
       
     {% endif %}
    }
    @media only screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} {
        --topSpacer: {{ section.settings.top_space_mobile }}px;
        --bottomSpacer: {{ section.settings.bottom_space_mobile }}px;
        {% if section.settings.border_radius > 30 %}
          --sectionRadius: calc({{ section.settings.border_radius }}px / 2);
        {% else %}
          --sectionRadius:{{ section.settings.border_radius }}px;
        {% endif %}
        {% if section.settings.mobile_media_height == "100vh" %}
          --mediaHeight: {{ section.settings.mobile_media_height }};
        {% else %}
          --mediaHeight: {{ section.settings.mobile_custom_height }}px;
        {% endif %}
      }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "t:sections.video.name",
  "class": "video-banner-section",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer","custom.Overlay"] },
  "blocks": [
   { 
    "type": "_heading"
   },
   {
    "type": "_description"
   }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.headers.general"
    },
    {
      "type": "checkbox",
      "id": "header_transparent",
      "label": "t:sections.all.headers.header_transparent.label",
      "default": false,
      "info": "t:sections.all.headers.header_transparent.info"
    },
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:sections.all.settings.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:sections.all.settings.section_visibility.always.label",
          "value": "always"
        },
        {
          "label": "t:sections.all.settings.section_visibility.small_devices.label",
          "value": "small"
        },
        {
          "label": "t:sections.all.settings.section_visibility.large_devices.label",
          "value": "large"
        }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "t:sections.all.settings.colors.label"
    },
    {
      "type": "select",
      "id": "color_type",
      "label": "t:sections.all.settings.color_background.label",
      "default": "solid",
      "options": [
        {
          "label": "t:sections.all.settings.color_background.options.background_solid",
          "value": "solid"
        },
        {
          "label": "t:sections.all.settings.color_background.options.background_gradiant",
          "value": "gradient"
        }
      ]
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "t:sections.all.settings.container_width.label",
      "default": "container-narrow",
      "options": [
        {
          "label": "t:sections.all.settings.container_width.small.label",
          "value": "container-small"
        },
        {
          "label": "t:sections.all.settings.container_width.standard.label",
          "value": "container"
        },
        {
          "label": "t:sections.all.settings.container_width.container_wide.label",
          "value": "container-wide"
        },
        {
          "label": "t:sections.all.settings.container_width.container_edge.label",
          "value": "container-narrow"
        },
        {
          "label": "t:sections.all.settings.container_width.full_width.label",
          "value": "container-full"
        }
      ]
    },
    {
      "type": "select",
      "id": "rounded_corners",
      "label": "t:sections.all.settings.rounded_corners.label",
      "options": [
        {
          "label": "t:sections.all.settings.rounded_corners.sharp.label",
          "value": "none"
        },
        {
          "label": "t:sections.all.settings.rounded_corners.rounded.label",
          "value": "all"
        }
      ],
      "default": "all"
    },
    {
      "type": "select",
      "id": "rounded_corners_type",
      "label": "t:sections.all.settings.rounded_corners_type.label",
      "visible_if": "{{ section.settings.rounded_corners == 'all' }}",
      "options": [
        {
          "label": "t:sections.all.settings.rounded_corners_type.option_0.label",
          "value": "layout-rounded-top"
        },
        {
          "label": "t:sections.all.settings.rounded_corners_type.option_1.label",
          "value": "layout-rounded-bottom"
        },
        {
          "label": "t:sections.all.settings.rounded_corners_type.option_2.label",
          "value": "layout-rounded"
        }
      ],
      "default": "layout-rounded"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:sections.all.settings.corner_radius.label",
      "info": "t:sections.all.settings.card_radius.info",
      "min": 2,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 10,
      "visible_if": "{{ section.settings.rounded_corners == 'all' }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.section_spacing"
    },
    {
      "type": "select",
      "id": "select_type",
      "label": "t:sections.all.settings.section_spacing.choose_from.label",
      "options": [
        {
          "label": "t:sections.all.settings.section_spacing.choose_from.options.desktop.label",
          "value": "desktop"
        },
        {
          "label": "t:sections.all.settings.section_spacing.choose_from.options.mobile.label",
          "value": "mobile"
        }
      ],
      "default": "desktop"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:sections.all.settings.section_spacing.top_spacing.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.select_type == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:sections.all.settings.section_spacing.bottom_spacing.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.select_type == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:sections.all.settings.section_spacing.top_spacing.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.select_type == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:sections.all.settings.section_spacing.bottom_spacing.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.select_type == 'mobile' }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.layout"
    },
    {
      "type": "select",
      "id": "desktop_media_height",
      "label": "t:sections.all.settings.media_height.video_height",
      "default": "custom",
      "options": [
        {
          "label": "t:sections.all.settings.media_height.custom_height",
          "value": "custom"
        },
        {
          "label": "t:sections.all.settings.media_height.full_screen",
          "value": "100vh"
        }
      ]
    },
    {
      "type": "range",
      "id": "desktop_custom_height",
      "label": "t:sections.all.settings.media_height.custom_height",
      "min": 400,
      "max": 1000,
      "default": 500,
      "step": 10,
      "unit": "px",
      "visible_if": "{{ section.settings.desktop_media_height == 'custom' }}"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:sections.video.settings.autoplay.label",
      "default":false
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Enable loop",
      "default":false
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.Shopify_hosted_video"
    },
    {
      "type": "video",
      "id": "desktop_video",
      "label": "t:sections.all.headers.video"
    },
    {
      "type": "header",
      "content": "t:sections.all.settings.video_url.header"
    },
    {
      "type": "video_url",
      "id": "desktop_url",
      "label": "t:sections.all.settings.video_url.settings.url.label",
      "accept": ["vimeo", "youtube"],
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc"

    },
    {
      "type": "image_picker",
      "id": "desktop_cover_image",
      "label": "t:sections.all.settings.video_url.settings.cover_image.label"
    },
    {
      "type": "text",
      "id": "desktop_alt_text",
      "label": "t:sections.all.settings.video_url.settings.video_alt_text.label",
      "info": "t:sections.all.settings.video_url.settings.video_alt_text.info"
    },
    {
      "type": "header",
      "content":"t:sections.all.settings.overlay.header"
    },
    {
      "type": "checkbox",
      "id": "enable_overlay",
      "label": "t:sections.all.settings.overlay.enable_overlay.label",
      "default": false
    },
    {
      "type": "select",
      "id": "overlay_style",
      "label": "t:sections.all.settings.overlay.style.label",
      "options": [
        {
          "label": "t:sections.all.settings.overlay.style.options__0.label",
          "value": "solid"
        },
        {
          "label": "t:sections.all.settings.overlay.style.options__1.label",
          "value": "gradient"
        }
      ],
      "default": "solid"
    },
    {
      "type": "color_background",
      "id": "overlay_gradient",
      "label": "t:sections.all.settings.overlay.color.label",
      "default": "linear-gradient(0deg, rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.04) 100%)",
      "visible_if": "{{ section.settings.overlay_style == 'gradient' }}"
    },
    {
      "type": "color",
      "id": "overlay_solid",
      "label": "t:sections.all.settings.overlay.color.label",
      "alpha": true,
      "default": "#00000093",
      "visible_if": "{{ section.settings.overlay_style == 'solid' }}"
    },
    {
      "type": "header",
      "content":"t:sections.all.headers.content"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "t:sections.all.settings.text_alignment.label",
      "default": "justify-content-center text-center",
      "options": [
        { "label": "t:sections.all.settings.text_alignment.option_1", "value": "justify-content-start text-left" },
        { "label": "t:sections.all.settings.text_alignment.option_2", "value": "justify-content-center text-center" },
        { "label": "t:sections.all.settings.text_alignment.option_3", "value": "justify-content-end text-right" }
      ]
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "t:sections.all.settings.vertical_alignment.label",
      "default": "align-items-center",
      "options": [
        { "label": "t:sections.all.settings.vertical_alignment.option_1", "value": "align-items-start" },
        { "label": "t:sections.all.settings.vertical_alignment.option_2", "value": "align-items-center" },
        { "label": "t:sections.all.settings.vertical_alignment.option_3", "value": "align-items-end" }
      ]
    },
    {
      "type": "select",
      "id": "content_visibility",
      "label": "t:sections.video.settings.content_visibility.label",
      "default": "hidden_on_play",
      "options": [
        {
          "label":"t:sections.video.settings.content_visibility.option_0.label",
          "value": "always"
        },
        {
          "label":"t:sections.video.settings.content_visibility.option_1.label",
          "value":"hidden_on_play"
        }
      ]
    },
    {
      "type": "header",
      "content":"t:sections.video.settings.play_btn.label"
    },
    {
      "type": "text",
      "id": "play_btn_text",
      "default": "Play Now",
      "label": "t:sections.all.headers.text"
    },
    {
      "type": "color",
      "id": "play_btn_color",
      "label": "t:sections.all.headers.color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "t:sections.all.settings.mobile_layout.header"
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "t:sections.all.headers.video",
    },
    {
      "type": "video_url",
      "id": "mobile_url",
      "label": "t:sections.all.settings.video_url.settings.url.label",
      "accept": ["vimeo", "youtube"]
    },
    {
      "type": "image_picker",
      "id": "mobile_cover_image",
      "label": "t:sections.all.settings.video_url.settings.cover_image.label"
    },
    {
      "type": "select",
      "id": "mobile_media_height",
      "label": "t:sections.all.settings.media_height.video_height_mob",
      "default": "custom",
      "options": [
        {
          "label": "t:sections.all.settings.media_height.custom_height",
          "value": "custom"
        },
        {
          "label": "t:sections.all.settings.media_height.full_screen",
          "value": "100vh"
        }
      ]
    },
    {
      "type": "range",
      "id": "mobile_custom_height",
      "label": "t:sections.all.settings.media_height.custom_height",
      "min": 200,
      "max": 800,
      "default": 400,
      "step": 10,
      "unit": "px",
      "visible_if": "{{ section.settings.mobile_media_height == 'custom' }}"
    },
    {
      "type": "select",
      "id": "mobile_content_position",
      "label": "t:sections.all.settings.vertical_alignment.label",
      "default": "align-items-center",
      "options": [
        { "label": "t:sections.all.settings.vertical_alignment.option_1", "value": "align-items-start" },
        { "label": "t:sections.all.settings.vertical_alignment.option_2", "value": "align-items-center" },
        { "label": "t:sections.all.settings.vertical_alignment.option_3", "value": "align-items-end" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.video.presets.name",
      "category": "Storytelling",
       "blocks": [
        {
          "type": "_heading",
          "settings": {
            "text":"Video heading"
          }
        },
        {
          "type": "_description",
          "settings": {
            "description":"This is a placeholder description for the video. Replace this text with details about the content, purpose, or key highlights once available.",
            "description_size":"text"
          }
        }
       ]
    }
  ]
}
{% endschema %}
