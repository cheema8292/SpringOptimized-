{% comment %} {% stylesheet %}
{% endstylesheet %} {% endcomment %}
{{ 'trust-icons.css' | asset_url | stylesheet_tag }}
{% liquid
  assign loading = 'lazy'
  if section.index <= 2
    assign loading = 'eager'
  endif
%}

<div class="color-scheme {{ section.settings.color_scheme }} color-{{ section.settings.color_type }} section-spacing">
  <div class="{{ section.settings.container_width }} {% if section.settings.swipe_on_mobile %} m-pr-0{% endif %}">
    {% if section.blocks.size > 0 %}
      <div
        class="trust-icons-wrapper divider-layout-{{ section.settings.divider_layout }} {% if section.settings.swipe_on_mobile %} mobile-swipe {% endif %} mobile-column-{{ section.settings.columns_mobile }} column-desktop-{{ section.settings.columns_desktop }}"
        data-position
      >
        {% for block in section.blocks %}
          <div class="trust-icon-item icon-{{ section.settings.icon_position }}" {{ block.shopify_attributes }}>
            <div class="trust-icon-item-inner">
              <div class="trust-icon-block-icon trust-icon-{{ section.settings.icon_size }}">
                {% if block.settings.choose_from == 'custom-icon' %}
                  {% if block.settings.image != blank %}
                    <span class="media-card media-fixed">
                      {% liquid
                        assign trust_icon_default_alt = 'Trust icon - ' | append: forloop.index
                        assign trust_icon_image_alt = block.settings.image.alt | default: trust_icon_default_alt
                      %}
                      {{ block.settings.image | image_url: width: 1200, format: 'webp' | image_tag:
                        sizes: '(max-width: 767px) 100vw',
                        widths: '324, 416, 991, 1200',
                        decoding: 'async',
                        loading: 'lazy',
                        fetchpriority: 'auto',
                        alt: trust_icon_image_alt,
                        class: 'image-with-text-image'
                      }}
                    </span>
                  {% endif %}
                {% elsif block.settings.choose_from == 'list' %}
                  {% render 'svg-list-icons', icon_type: block.settings.icon %}
                {% endif %}
              </div>
              {% if block.settings.heading != blank or block.settings.description != blank %}
                <div class="trust-icon-content-block text-{{ section.settings.text_alignment }}">
                  {% if block.settings.heading != blank %}
                    <div class="trust-icon-heading {{ section.settings.heading_size }} heading-font h6">
                      {{ block.settings.heading | replace: '<a', '<a class="text-underline"' }}
                    </div>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    <p class="trust-icon-description {{ section.settings.description_size }}">
                      {{ block.settings.description }}
                    </p>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>
<style>
    #shopify-section-{{ section.id }}{
     --topSpacer: {{ section.settings.top_space_desktop }}px;
     --bottomSpacer:{{ section.settings.bottom_space_desktop }}px;
     --columnCount:{{ section.settings.columns_desktop }}
    }
    @media only screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} {
        --topSpacer: {{ section.settings.top_space_mobile }}px;
        --bottomSpacer:{{ section.settings.bottom_space_mobile }}px;
        --columnCount:{{ section.settings.columns_mobile }}
      }
    }
    @media only screen and (min-width: 768px) {
      #shopify-section-{{ section.id }} .trust-icons-wrapper.divider-layout-vertical .trust-icon-item:nth-child({{ section.settings.columns_desktop }}n) {
        border-right: 0;
      }
    }

    {% if section.settings.section_visibility == 'large' %}
      @media(max-width: 767px) {
        #shopify-section-{{ section.id }} {
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
</style>

