{% comment %}
  Renders loading-spinner.
  Accepts:
    - class: {string} css classes to replace the default ones (optional)

  Usage:
  {% render 'loading-spinner' %}
{% endcomment %}
<div class="{% if class %}{{ class }}{% else %}loading-spinner-dots dots-container hidden{% endif %}">
    <div class="dot"></div>
    <div class="dot"></div>
    <div class="dot"></div> 
</div>
