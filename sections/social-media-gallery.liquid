{{ 'social-media-gallery.css' | asset_url | stylesheet_tag }}
{% liquid
  assign loading = 'lazy'
  assign fetch_priority = 'auto'
  if section.index <= 3
    assign fetch_priority = 'high'
    assign loading = 'eager'
  endif
  assign column_count = section.settings.column_count
  assign mobile_column_count = section.settings.columns_mobile
  if column_count > section.blocks.size
    assign column_count = section.blocks.size
  endif
  if mobile_column_count > section.blocks.size
    assign mobile_column_count = section.blocks.size
  endif
%}
<div class="color-scheme {{ section.settings.color_scheme }} color-{{ section.settings.color_type }} section-spacing">
  <div class="{{ section.settings.container_width }}{% if section.settings.enable_mobile_swipe %} m-pr-0{% endif %}">
    {% if section.blocks.size > 0 or section.settings.heading != blank or section.settings.description != blank %}
      <div class="social-media-gallery-main {{ section.settings.layout_position }}-position">
        {% assign text_alignment = 'text-' | append: section.settings.content_alignment %}
        {% capture description_data %}
        {% if section.settings.description != blank %}
            <p class="section-description {{ section.settings.description_size }}">{{ section.settings.description | newline_to_br }}</p>
        {% endif %}
        {% if  section.settings.button_title != blank %}
            {% render 'button-appearance' ,
              button_text:section.settings.button_title,
              button_url:section.settings.button_link,
              button_style:section.settings.button_style,
              is_open_in_new_tab:section.settings.is_open_in_new_tab,
              class:'social-media-gallery-button'
            %}
        {% endif %}
        {% endcapture %}
        {% render 'section-heading',
          section_heading_tag: section.settings.heading_tag,
          section_heading_size: section.settings.heading_size,
          section_heading_content: section.settings.heading,
          section_heading_highlight_text: section.settings.highlight_text,
          section_heading_highlight_font: section.settings.highlight_font,
          section_extra_classes: text_alignment,
          extra_html_content: description_data
        %}
        {% if section.blocks.size > 0 %}
          <div class="social-media-gallery-wrapper d-none md-grid ">
            {% for i in (1..column_count) %}
              <div class="social-media-gallery-items ">
                {% for block in section.blocks %}
                  {% assign col_index = forloop.index0 | modulo: column_count %}
                  {% assign current_col = i | minus: 1 %}
                  {% if col_index == current_col %}
                    {% assign image_ratio = block.settings.aspect_ratio %}
                    <div class="social-media-gallery-item" {{ block.shopify_attributes }}>
                      {% if block.settings.image != blank %}
                        {% if block.settings.aspect_ratio == 'auto' %}
                          {% assign image_ratio = block.settings.image.aspect_ratio %}
                        {% endif %}
                      {% else %}
                        {% if block.settings.aspect_ratio == 'auto' %}
                          {% assign image_ratio = '1/1' %}
                        {% endif %}
                      {% endif %}
                      {% if block.settings.button_url != blank %}
                        <a
                          href="{{ block.settings.button_url }}"
                          class="social-media-gallery-item-inner pos-relative img-hover d-block"
                        >
                      {% else %}
                        <div class="social-media-gallery-item-inner pos-relative img-hover">
                      {% endif %}
                      <div class="social-media-gallery-img media-wrapper">
                        <div class="media-card media-adapt" style="--imageRatio:{{ image_ratio }};">
                          {% if block.settings.image != blank %}
                            {% liquid
                              assign default_alt = 'Social media gallery image' | escape
                              assign image_alt = block.settings.image.alt | default: default_alt
                            %}
                            {{
                              block.settings.image
                              | image_url: width: 3840, format: 'webp'
                              | image_tag:
                                sizes: '(max-width: 767px) 100vw, (max-width: 1024px) 100vw, (max-width: 1367px) 100vw, (max-width: 1599px) 100vw, 100vw',
                                widths: '180, 240, 320, 375, 480, 600, 768, 900, 1024, 1280, 1600, 1920, 2560, 3840',
                                decoding: 'async',
                                loading: loading,
                                fetchpriority: fetch_priority,
                                alt: image_alt
                            }}
                          {% else %}
                            {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                          {% endif %}
                        </div>
                      </div>
                      <div class="social-media-gallery-content">
                        <div class="social-media-gallery-content-info">
                          <div class="social-media-gallery-content-img">
                            <div class="media-card media-adapt" style="--imageRatio:1/1;">
                              {% if block.settings.avtar_image != blank %}
                                {% liquid
                                  assign avatar_default_alt = 'Social media gallery avatar image' | escape
                                  assign avatar_image_alt = block.settings.avtar_image.alt | default: avatar_default_alt
                                %}
                                {{
                                  block.settings.avtar_image
                                  | image_url: width: 991, format: 'webp'
                                  | image_tag:
                                    sizes: '100vw',
                                    widths: '375, 550, 750, 991',
                                    decoding: 'async',
                                    loading: 'lazy',
                                    fetchpriority: 'auto',
                                    alt: avatar_image_alt
                                }}
                              {% else %}
                                {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                              {% endif %}
                            </div>
                          </div>
                          {% if block.settings.custom_title != blank %}
                            <div class="social-media-gallery-content-title">{{ block.settings.custom_title }}</div>
                          {% else %}
                            <div class="social-media-gallery-content-title">Avtar title</div>
                          {% endif %}
                        </div>
                        {% if block.settings.media_type != 'none' %}
                          <div class="social-media-gallery-content-icon">
                            {% render 'svg-list-icons', icon_type: block.settings.media_type %}
                          </div>
                        {% endif %}
                      </div>
                      {% if block.settings.button_url != blank %}
                        </a>
                      {% else %}
                        </div>
                      {% endif %}
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            {% endfor %}
          </div>
          <div class="social-media-gallery-wrapper  d-grid md-none {% if section.settings.enable_mobile_swipe %}mobile-swipe{% endif %} mobile-stacked mobile-column-{{ section.settings.columns_mobile }}">
            {% for i in (1..mobile_column_count) %}
              <div class="social-media-gallery-items">
                {% for block in section.blocks %}
                  {% assign col_index = forloop.index0 | modulo: mobile_column_count %}
                  {% assign current_col = i | minus: 1 %}
                  {% if col_index == current_col %}
                    {% assign image_ratio = block.settings.aspect_ratio %}
                    <div class="social-media-gallery-item" {{ block.shopify_attributes }}>
                      {% if block.settings.image != blank %}
                        {% if block.settings.aspect_ratio == 'auto' %}
                          {% assign image_ratio = block.settings.image.aspect_ratio %}
                        {% endif %}
                      {% else %}
                        {% if block.settings.aspect_ratio == 'auto' %}
                          {% assign image_ratio = '1/1' %}
                        {% endif %}
                      {% endif %}
                      {% if block.settings.button_url != blank %}
                        <a
                          href="{{ block.settings.button_url }}"
                          class="social-media-gallery-item-inner pos-relative img-hover d-block"
                        >
                      {% else %}
                        <div class="social-media-gallery-item-inner pos-relative img-hover">
                      {% endif %}
                      <div class="social-media-gallery-img media-wrapper">
                        <div class="media-card media-adapt" style="--imageRatio:{{ image_ratio }};">
                          {% if block.settings.image != blank %}
                            {% liquid
                              assign mobile_default_alt = 'Social media gallery image' | escape
                              assign mobile_image_alt = block.settings.image.alt | default: mobile_default_alt
                            %}
                            {{
                              block.settings.image
                              | image_url: width: 3840, format: 'webp'
                              | image_tag:
                                sizes: '(max-width: 767px) 100vw',
                                widths: '320, 480, 640, 750, 828, 1080, 1200, 1600',
                                decoding: 'async',
                                loading: loading,
                                fetchpriority: fetch_priority,
                                alt: mobile_image_alt
                            }}
                          {% else %}
                            {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                          {% endif %}
                        </div>
                      </div>
                      <div class="social-media-gallery-content">
                        <div class="social-media-gallery-content-info">
                          <div class="social-media-gallery-content-img">
                            <div class="media-card media-adapt" style="--imageRatio:1/1;">
                              {% if block.settings.avtar_image != blank %}
                                {% liquid
                                  assign avatar_mobile_default_alt = 'Social media gallery avatar image' | escape
                                  assign avatar_mobile_image_alt = block.settings.avtar_image.alt | default: avatar_mobile_default_alt
                                %}
                                {{
                                  block.settings.avtar_image
                                  | image_url: width: 991, format: 'webp'
                                  | image_tag:
                                    sizes: '100vw',
                                    widths: '375, 550, 750, 991',
                                    decoding: 'async',
                                    loading: 'lazy',
                                    fetchpriority: 'auto',
                                    alt: avatar_mobile_image_alt
                                }}
                              {% else %}
                                {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                              {% endif %}
                            </div>
                          </div>
                          {% if block.settings.custom_title != blank %}
                            <div class="social-media-gallery-content-title">{{ block.settings.custom_title }}</div>
                          {% else %}
                            <div class="social-media-gallery-content-title">Avtar title</div>
                          {% endif %}
                        </div>
                        {% if block.settings.media_type != 'none' %}
                          <div class="social-media-gallery-content-icon">
                            {% render 'svg-list-icons', icon_type: block.settings.media_type %}
                          </div>
                        {% endif %}
                      </div>
                      {% if block.settings.button_url != blank %}
                        </a>
                      {% else %}
                        </div>
                      {% endif %}
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} {
    --topSpacer: {{ section.settings.top_space_desktop }}px;
    --bottomSpacer:{{ section.settings.bottom_space_desktop }}px;
    --columnCount:{{ column_count }};
    --blockRadius:{{ section.settings.border_radius }}px;
    --columnGap: {{ section.settings.column_gap  }}px;

  }
  {% if section.settings.highlight_text == 'color' %}
    #shopify-section-{{ section.id }} .text-highlight-color {
      --highlightColor: {{ section.settings.text_color }};
    }
  {% elsif section.settings.highlight_text == 'gradiant' %}
    #shopify-section-{{ section.id }} .text-highlight-gradiant{
      --highlightColor:{{ section.settings.gradiant_color }};
    }
  {% endif %}
  @media only screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      --topSpacer: {{ section.settings.top_space_mobile }}px;
      --bottomSpacer: {{ section.settings.bottom_space_mobile }}px;
      --columnCount:{{ section.settings.columns_mobile  }};
      --columnGap: {{ section.settings.mobile_column_gap  }}px;
      {% if section.settings.border_radius > 20 %}
        --blockRadius: calc( {{ section.settings.border_radius }}px / 2);
      {% else %}
        --blockRadius: {{ section.settings.border_radius }}px ;
      {% endif %}
    }
  }
  {% if section.settings.section_visibility == 'large' %}
    @media(max-width: 767px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media(min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "t:sections.social-media-gallery.name",
  "class": "social-media-gallery-section",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer", "custom.Overlay"] },
  "blocks": [
    {
      "type": "social-media",
      "name": "t:sections.social-media-gallery.blocks.name",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.all.headers.image"
        },
        {
          "type": "select",
          "id": "aspect_ratio",
          "label": "t:sections.all.settings.aspect_ratio.label",
          "default": "1/1",
          "options": [
            {
              "label": "t:sections.all.settings.aspect_ratio.options__1.label",
              "value": "auto"
            },
            {
              "label": "t:sections.all.settings.aspect_ratio.options__2.label",
              "value": "1/1"
            },
            {
              "label": "t:sections.all.settings.aspect_ratio.options__3.label",
              "value": "3/4"
            },
            {
              "label": "t:sections.all.settings.aspect_ratio.options__4.label",
              "value": "2/3"
            },
            {
              "label": "t:sections.all.settings.aspect_ratio.options__5.label",
              "value": "4/3"
            }
          ]
        },
        {
          "type": "image_picker",
          "id": "avtar_image",
          "label": "t:sections.social-media-gallery.blocks.avtar_image.label"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "t:sections.all.settings.icon.name",
          "options": [
            {
              "label": "t:sections.social-media-gallery.settings.icon_list.none",
              "value": "none"
            },
            {
              "label": "t:sections.social-media-gallery.settings.icon_list.instagram",
              "value": "instagram"
            },
            {
              "label": "t:sections.social-media-gallery.settings.icon_list.facebook",
              "value": "facebook"
            },
            {
              "label": "t:sections.social-media-gallery.settings.icon_list.twitter",
              "value": "twitter"
            },
            {
              "label": "t:sections.social-media-gallery.settings.icon_list.snapchat",
              "value": "snapchat"
            },
            {
              "label": "t:sections.social-media-gallery.settings.icon_list.tiktok",
              "value": "tiktok"
            },
            {
              "label": "t:sections.social-media-gallery.settings.icon_list.tumblr",
              "value": "tumblr"
            },
            {
              "label": "t:sections.social-media-gallery.settings.icon_list.vimeo",
              "value": "vimeo"
            },
            {
              "label": "t:sections.social-media-gallery.settings.icon_list.youtube",
              "value": "youtube"
            }
          ],
          "default": "none"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "t:sections.all.headers.title"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "t:sections.all.headers.link"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.headers.general"
    },
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:sections.all.settings.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:sections.all.settings.section_visibility.always.label",
          "value": "always"
        },
        {
          "label": "t:sections.all.settings.section_visibility.small_devices.label",
          "value": "small"
        },
        {
          "label": "t:sections.all.settings.section_visibility.large_devices.label",
          "value": "large"
        }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "t:sections.all.settings.colors.label"
    },
    {
      "type": "select",
      "id": "color_type",
      "label": "t:sections.all.settings.color_background.label",
      "default": "solid",
      "options": [
        {
          "label": "t:sections.all.settings.color_background.options.background_solid",
          "value": "solid"
        },
        {
          "label": "t:sections.all.settings.color_background.options.background_gradiant",
          "value": "gradient"
        }
      ]
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "t:sections.all.settings.container_width.label",
      "default": "container-narrow",
      "options": [
        {
          "label": "t:sections.all.settings.container_width.small.label",
          "value": "container-small"
        },
        {
          "label": "t:sections.all.settings.container_width.standard.label",
          "value": "container"
        },
        {
          "label": "t:sections.all.settings.container_width.container_wide.label",
          "value": "container-wide"
        },
        {
          "label": "t:sections.all.settings.container_width.container_edge.label",
          "value": "container-narrow"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.section_spacing"
    },
    {
      "type": "select",
      "id": "select_type",
      "label": "t:sections.all.settings.section_spacing.choose_from.label",
      "options": [
        {
          "label": "t:sections.all.settings.section_spacing.choose_from.options.desktop.label",
          "value": "desktop"
        },
        {
          "label": "t:sections.all.settings.section_spacing.choose_from.options.mobile.label",
          "value": "mobile"
        }
      ],
      "default": "desktop"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:sections.all.settings.section_spacing.top_spacing.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.select_type == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:sections.all.settings.section_spacing.bottom_spacing.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.select_type == 'desktop' }}"
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:sections.all.settings.section_spacing.top_spacing.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.select_type == 'mobile' }}"
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:sections.all.settings.section_spacing.bottom_spacing.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "visible_if": "{{ section.settings.select_type == 'mobile' }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.desktop_layout"
    },
    {
      "type": "select",
      "id": "layout_position",
      "label": "Layout",
      "default": "horizontal",
      "options": [
        {
          "label": "t:sections.social-media-gallery.settings.layout_position.option_0.label",
          "value": "horizontal"
        },
        {
          "label": "t:sections.social-media-gallery.settings.layout_position.option_1.label",
          "value": "vertical"
        }
      ]
    },
    {
      "type": "range",
      "id": "column_count",
      "label": "t:sections.all.settings.column_count.label",
      "default": 4,
      "min": 3,
      "max": 6,
      "step": 1
    },
    {
      "type": "range",
      "label": "t:sections.all.settings.column_gap.label",
      "id": "column_gap",
      "min": 0,
      "max": 15,
      "step": 1,
      "default": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:sections.all.settings.card_radius.label",
      "info": "t:sections.all.settings.card_radius.info",
      "min": 0,
      "max": 30,
      "default": 5,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "t:sections.all.settings.mobile_layout.header"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "t:sections.all.settings.mobile_layout.mobile_column_count.label",
      "default": "1",
      "options": [
        {
          "value": "1",
          "label": "t:sections.all.settings.mobile_layout.mobile_column_count.options__0.label"
        },
        {
          "value": "2",
          "label": "t:sections.all.settings.mobile_layout.mobile_column_count.options__1.label"
        }
      ]
    },
    {
      "type": "range",
      "label": "t:sections.all.settings.column_gap.label",
      "id": "mobile_column_gap",
      "min": 0,
      "max": 15,
      "step": 1,
      "default": 5,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "enable_mobile_swipe",
      "label": "t:sections.all.settings.mobile_layout.enable_swipe.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.section_header"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.all.headers.heading",
      "default": "Social media gallery",
      "info": "t:sections.all.settings.heading_info.info"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.all.settings.heading_tag.label",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        },
        {
          "value": "div",
          "label": "Div"
        },
        {
          "value": "span",
          "label": "Span"
        },
        {
          "value": "p",
          "label": "P"
        }
      ],
      "default": "h3"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.all.settings.heading_size.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.settings.heading_size.options.heading_xl"
        },
        {
          "value": "h2",
          "label": "t:sections.all.settings.heading_size.options.heading_l"
        },
        {
          "value": "h3",
          "label": "t:sections.all.settings.heading_size.options.heading_m"
        },
        {
          "value": "h4",
          "label": "t:sections.all.settings.heading_size.options.heading_s"
        },
        {
          "value": "h5",
          "label": "t:sections.all.settings.heading_size.options.heading_xs"
        },
        {
          "value": "h6",
          "label": "t:sections.all.settings.heading_size.options.heading_xxs"
        }
      ],
      "default": "h3"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.all.headers.description",
      "default": "Use this text to share information about your brand with your customers."
    },
    {
      "type": "select",
      "id": "description_size",
      "label": "t:sections.all.settings.description_size.label",
      "options": [
        {
          "value": "text-xlarge",
          "label": "t:sections.all.settings.description_size.options.text-xlarge"
        },
        {
          "value": "text-large",
          "label": "t:sections.all.settings.description_size.options.text-large"
        },
        {
          "value": "text-medium",
          "label": "t:sections.all.settings.description_size.options.text-medium"
        },
        {
          "value": "text",
          "label": "t:sections.all.settings.description_size.options.text"
